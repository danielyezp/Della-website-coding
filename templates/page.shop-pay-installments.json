    "collapsible_row_image_rPFGXC": {
      "type": "collapsible-row-image",
      "blocks": {
        "item_nVcBE8": {
          "type": "item",
          "settings": {
            "icon": "none",
            "title": "1. How do I start the installment payment process?",
            "text": "<p>To begin, add all the products you wish to purchase to your cart. During checkout, choose Shop Pay as your payment option. Follow the steps to select the \"Pay in monthly installments\" option.</p>"
          }
        },
        "item_F8pmTh": {
          "type": "item",
          "settings": {
            "icon": "none",
            "title": "2. What payment plans are available?",
            "text": "<p>The available installment plans depend on your purchase. Shop Pay, powered by Affirm, may offer options such as 3, 6, 12, 18, or 24 months based on the product. You'll see the specific options during the checkout process.</p>"
          }
        },
        "item_9zWmMi": {
          "type": "item",
          "settings": {
            "icon": "none",
            "title": "3. Will checking eligibility affect my credit score?",
            "text": "<p>No, checking your eligibility for installments through Shop Pay uses a soft credit pull, which will not impact your credit score.</p>"
          }
        },
        "item_66HFC3": {
          "type": "item",
          "settings": {
            "icon": "none",
            "title": "4. Are there any hidden fees?",
            "text": "<p>Shop Pay and Affirm are transparent. There are no late fees, prepayment penalties, or hidden charges.</p>"
          }
        },
        "item_zrtCRT": {
          "type": "item",
          "settings": {
            "icon": "none",
            "title": "5. What if I need to return an item I financed?",
            "text": "<p>If you need to return a financed item, contact our support team to initiate the return process. Once the return is approved and processed, Affirm will adjust your loan or refund any applicable payments.</p>"
          }
        },
        "item_7aUCdW": {
          "type": "item",
          "settings": {
            "icon": "none",
            "title": "6. Can I use a credit card to pay for Shop Pay installments?",
            "text": "<p>No, Shop Pay Installments, powered by Affirm, currently only supports debit cards for installment payments. Credit cards and prepaid cards are not eligible.</p>"
          }
        },
        "item_QWXKUp": {
          "type": "item",
          "settings": {
            "icon": "none",
            "title": "7. How do I verify my eligibility for installments?",
            "text": "<p>You can verify your eligibility for installments by using the \"Check if you qualify\" option, available both on the product page and during checkout. Simply enter the required details to view the available plans for your purchase.</p>"
          }
        }
      },
