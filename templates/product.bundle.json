y Order?<br\/>Please <a href=\"\/pages\/contact\" target=\"_blank\" title=\"Contact Us\">contact us<\/a> immediately.<br\/><br\/>For the full shipping policy, click here to view our <a href=\"\/policies\/shipping-policy\" target=\"_blank\" title=\"Shipping Policy\">shipping policy<\/a>.<br\/><strong><br\/>Return <\/strong><br\/><br\/>We offer return guarantees to ensure your satisfaction with every DELLA purchase.<br\/><br\/>DELLA provides comprehensive assistance for all orders within <strong>30 days<\/strong> of purchase. If you're not satisfied with your product within <strong>30 days<\/strong> of purchase from dellahome.com, you can return the product for a full refund.Products must be returned in their original operating condition, including all accessories and packaging.The customer is responsible for return shipping costs.<br\/><br\/>If a product defect is confirmed, DELLA will, at its discretion, provide the necessary replacement parts free of charge. DELLA will also cover all shipping expenses for the delivery of replacement parts.<br\/><br\/>Need to Start a Return?<br\/>To initiate a return, call us at <strong>(800) 863-4143<\/strong> or contact our live chat team.<br\/><br\/>For full return terms, click here to view our <a href=\"https:\/\/dellahome.com\/policies\/refund-policy\" target=\"_blank\" title=\"https:\/\/dellahome.com\/policies\/refund-policy\">return policy<\/a>.<\/p>","page_for_content":"","custom_liquid":""}},"accordion-3":{"type":"accordion","settings":{"expand_by_default":false,"column_placement":"right","heading":"Lifetime warranty","heading_tag":"h3","content":"{{ product.metafields.custom.barrel_lifetime_warranty_text | metafield_tag }}","page_for_content":"","custom_liquid":""}},"product_callouts_ANC8VU":{"type":"product_callouts","disabled":true,"settings":{"title":"","title_tag":"h3","add_box":true,"add_dividers":false,"background_color":"#f4f3ed","style":"default","icon_1":"package-closed","custom_icon_image_1":"shopify:\/\/shop_ima