    "collapsible_row_image_EnHCz8": {
      "type": "collapsible-row-image",
      "blocks": {
        "item_zeawTM": {
          "type": "item",
          "settings": {
            "icon": "none",
            "title": "1. Who is eligible to join the Della Wholesalers Program?",
            "text": "<p>Any business with a valid seller certificate and reseller permit can apply to join our program.</p>"
          }
        },
        "item_z4nqbj": {
          "type": "item",
          "settings": {
            "icon": "none",
            "title": "2. What discounts do wholesale partners receive?",
            "text": "<p>Wholesale partners enjoy a 20% discount on Local Pickup Orders and a 10% discount on Dropshipping Orders.</p>"
          }
        },
        "item_V7GEhi": {
          "type": "item",
          "settings": {
            "icon": "none",
            "title": "3. How do I apply for the program?",
            "text": "<p>Simply fill out the application form on our Wholesalers Program page and submit the required documents, including your seller certificate and reseller permit.</p>"
          }
        },
        "item_BVAWQg": {
          "type": "item",
          "settings": {
            "icon": "none",
            "title": "4. How long does it take to get approved?",
            "text": "<p>Once you submit your application, our team will review it promptly. We will contact you via phone or email with the next steps after approval.</p>"
          }
        },
        "item_neGdzB": {
          "type": "item",
          "settings": {
            "icon": "none",
            "title": "5. Where is the local pickup location?",
            "text": "<p>Our local pickup locations are available at the following addresses:<br/><span style=\"text-decoration:underline\">19301 E Walnut Dr N, City of Industry, CA 91748</span></p><p><span style=\"text-decoration:underline\">10710 Bonnie View Rd, Dallas, TX 75241</span></p><p><span style=\"text-decoration:underline\">631 Omni Industrial Blvd, Summerville, SC 29483</span></p>"
          }
        },
        "item_Nndawh": {
          "type": "item",
          "settings": {
            "icon": "none",
            "title": "6. Can I update my business details or contact Della for more questions?",
            "text": "<p>Yes, you can contact our customer support team to update your business information after approval. For further assistance, reach us at (800) 863-4143 or via our 24/7 live chat.</p>"
          }
        }
      },
      "block_order": [
