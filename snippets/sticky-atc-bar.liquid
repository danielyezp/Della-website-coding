{%- comment -%}
  Renders the sticky add to cart bar on the product page.
  Must be rendered within a product form.

  Required parameters:

  * local_settings: { Object } The bar's settings, taken from the buy button block on the product page.
  * prod: { Object } The product to render with.
  * current_variant: { Object } The selected_or_first_available_variant of the product.
  * featured_media: { Object } The initial media shown.
  * aspect_ratio: { String } The value which determines the aspect ratio of the media.
  * price_content_type: { String } "price" or "custom" or "hide" after checking both $0 and sold out pricing display settings
  * custom_price_content: { String } The translation to populate price if sold out or free, depending on logic checks and settings
{%- endcomment -%}

{%- liquid
  assign product_available_label = 'products.product.add_to_cart' | t
  assign product_unavailable_label = 'products.product.sold_out' | t

  if template.suffix == 'preorder'
    assign product_available_label = 'products.product.preorder' | t
  endif

  capture options_csl
    for option in current_variant.options
      echo option
      unless forloop.last
        echo ', '
      endunless
    endfor
  endcapture
-%}

<div
  class="sticky-atc-bar is-hidden"
  {{ divider_style }}
  data-divider-style="{{ local_settings.divider_width }}"
  data-show-desktop="{{ local_settings.enable_sticky_atc_bar_desktop }}"
  data-show-mobile="{{ local_settings.enable_sticky_atc_bar_mobile }}"
>
  <div class="sticky-atc-bar__inner">
    <div class="sticky-atc-bar__details">
      <div class="sticky-atc-bar__media product__media">
        {%- for media in prod.media -%}
          <div
            class="product__media-item {% unless media.id == featured_media.id %} hidden{% endunless %}"
            data-media-item-id="{{ media.id }}"
            data-media-type="{{ media.media_type }}"
            data-product-media-wrapper
          >
            {% render 'image',
              image: media,
              id: media.id,
              wrapper_class: 'sticky-atc-bar__image',
              aspect_ratio: aspect_ratio,
              sizes: '64px',
              fetch_priority: 'low',
              src_set_type: 'thumbnail'
            %}
          </div>
        {% endfor -%}
      </div>

      <div class="sticky-atc-bar__meta">
        <h3 class="ff-subheading fs-body-250">{{ prod.title }}</h3>

        {%- unless prod.has_only_default_variant %}
          <div class="sticky-atc-bar__meta-options">
          {%- for option in prod.options_with_values -%}
            <div class="sticky-atc-bar__meta-option">
              <span class="sticky-atc-bar__meta-option-name ff-body fs-body-50">{{ option.name }}:</span>
              <span class="sticky-atc-bar__meta-option-value ff-body fs-body-50 js-option-value">{{ current_variant.options[forloop.index0] }}</span>
            </div>
          {%- endfor -%}
          </div>
        {%- endunless -%}
      </div>
    </div>
    <div class="sticky-atc-bar__button">
      {%- unless prod.has_only_default_variant %}
        <button
          type="button"
          class="sticky-atc-bar__meta-change-option-trigger fs-body-50"
          data-change-option-trigger
        >
          {{ 'products.product.change_option' | t }}
        </button>
      {%- endunless -%}
      <button
        type="submit"
        name="add"
        {% unless current_variant.available %}
          aria-disabled="true" disabled
        {% endunless %}
        aria-label="{% unless current_variant.available %}{{ product_unavailable_label }}{% else %}{{ product_available_label }}{% endunless %}"
        class="product-form__cart-submit btn btn--medium btn--full btn--solid btn--dark"
        data-add-to-cart
        data-lang-available="{{ product_available_label }}"
        data-lang-unavailable="{{ 'product.unavailable' | t }}"
        data-lang-sold-out="{{ 'product.sold_out' | t }}"
      >
        <span data-add-to-cart-text>
          {%- unless current_variant.available -%}
            {{ product_unavailable_label }}
          {%- else -%}
            {{ product_available_label }}
          {%- endunless -%}
        </span>
        <span> - </span>
        <div class="sticky-atc-bar__price product__price fs-body-50">
          {%- if prod != blank -%}
            <span class="visually-hidden" data-compare-text>{{ 'products.product.regular_price' | t }}</span>
            <span data-price>
              {% if price_content_type == 'price' %}
                {{ current_variant.price | money }}
              {%- elsif price_content_type == 'custom' -%}
                {{- custom_price_content }}
              {% endif %}
            </span>
            <s class="t-subdued" data-compare-price>
              {%- if price_content_type == 'price' and current_variant.compare_at_price > current_variant.price -%}
                {{- current_variant.compare_at_price | money -}}
              {%- endif -%}
            </s>
          {%- else -%}
            <span>{{ 9999 | money }}</span>
          {%- endif -%}
        </div>

        <div class="btn__loading-wrap">
          <div class="btn__loading-bar"></div>
        </div>
      </button>
    </div>
  </div>
</div>
