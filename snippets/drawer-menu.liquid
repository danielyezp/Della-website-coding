{% liquid
  comment
    Renders the mobile drawer including navigation, localization, account login

    Required parameters:
      - links: { Object } The linklists[menu].linkslinks passed through from the header.
      - sub_links: { Object } The linklists[sub_menu].links passed through from the header.
      - secondary_links: { Object } linklists[secondary_menu].links passed through from the header.
      - locale_selector: { Boolean } True if locale settings enabled and there is more than 1 locale in the admin.
      - country_selector: { Boolean } True if country settings enabled and there is more than 1 country in the admin.
      - mobile_menu_image_blocks: { Object } Enabled mobile menu image blocks to pass into the drawer-menu-list snippet.
  endcomment

  assign account_visible = false
  assign show_social_media = show_social_media | default: false
  assign bottom_links = bottom_links | default: ''
  assign bottom_image = bottom_image | default: ''
  assign bottom_content = bottom_content | default: ''
  assign location_text = location_text | default: ''
  assign location_url = location_url | default: ''

  if shop.customer_accounts_enabled
    assign account_visible = true
  endif

  assign localization_option_count = 0

  if shop.published_locales.size > 1
    assign localization_option_count = localization_option_count | plus: 1
  endif

  if localization.available_countries.size > 1
    assign localization_option_count = localization_option_count | plus: 1
  endif

  assign has_first_level_mobile_menu_images = false
  assign mobile_menu_image_link_handles = ''
  assign second_level_mobile_menu_image_link_handles = ''

  for mobile_menu_image_block in mobile_menu_image_blocks
    if mobile_menu_image_block.settings.menu_name == blank
      # Check for first-level images and save settings
      assign has_first_level_mobile_menu_images = true
      assign mobile_menu_image_aspect_ratio = mobile_menu_image_block.settings.aspect_ratio
      assign mobile_menu_image_width = mobile_menu_image_block.settings.thumbnail_width

    else
      # Save list of parent links for second-level images
      assign current_menu_handle = mobile_menu_image_block.settings.menu_name | handle
      assign mobile_menu_image_link_handles = mobile_menu_image_link_handles | append: current_menu_handle | append: ', '
      assign second_level_mobile_menu_image_link_handles = second_level_mobile_menu_image_link_handles | append: current_menu_handle | append: ', '
    endif
  endfor
%}

{% capture account_link %}
  {% if account_visible -%}
    <div class="flex items-center gap-1 drawer-menu__account" data-list-item>
      {%- if account_icon != blank -%}
        {{ account_icon | image_url: width: 24 | image_tag: class: 'icon', loading: 'lazy', fetchpriority: 'low', decoding: 'async' }}
      {%- else -%}
        {%- render 'icon' with icon: 'header-account' -%}
      {%- endif -%}
      {%- if customer -%}
        {%-
            render 'button-block' with
            wrapper_class: 'drawer-menu__account-link',
            link: routes.account_url,
            label: 'Account',
            button_style: "btn--callout"
        -%}
        <span>/</span>
        {%-
            render 'button-block' with
            link: routes.account_logout_url,
            label: 'Logout',
            button_style: "btn--callout"
        -%}
      {% else %}
        {%-
            render 'button-block' with
            wrapper_class: 'drawer-menu__account-link',
            link: routes.account_url,
            label: 'Sign In',
            button_style: "btn--callout"
        -%}
      {%- endif -%}
    </div>
  {% endif %}
{% endcapture %}

{%- capture featured_banner -%}
  {%- if featured_banner_image != blank -%}
    <div class="drawer-menu__featured-banner">
      {%- if featured_banner_link != blank -%}
        <a href="{{ featured_banner_link }}">
      {%- endif -%}
      {%- render 'image',
        wrapper_class: 'drawer-menu__featured-banner-image',
        image: featured_banner_image
      -%}
      {%- if featured_banner_label != blank -%}
        <p class="ff-body fs-body-75 drawer-menu__featured-banner-label">{{ featured_banner_label }}</p>
      {%- endif -%}
      {%- if featured_banner_link != blank -%}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}
{%- endcapture -%}

<section
  class="
    drawer-menu
    {% if settings.enable_section_animations %}
      animation
      animation--drawer-menu
    {% endif %}
  "
  data-drawer-menu
  data-scroll-lock-ignore
  style="--item-height: 52px"
>
  <div class="drawer-menu__overlay" data-overlay></div>

  <div class="drawer-menu__panel">
    <button
      class="drawer-menu__close"
      type="button"
      data-close-drawer
      aria-label="{{ 'general.accessibility.close_menu' | t }}"
    >
      {% render 'icon-button', icon: 'header-menu-close' %}
    </button>

    <div class="drawer-menu__bottom">
      <div class="drawer-menu__all-links" data-depth="0" data-all-links data-in-initial-position="true">
        <div class="drawer-menu__contents" data-scroll-lock-ignore>
          <div class="drawer-menu__main" data-main role="navigation">
            <div class="drawer-menu__links-wrapper animation--drawer-menu-item">
              <div class="px-5">
                {%- if account_placement == 'top' -%}
                  <div class="drawer-menu__actions">
                    {{ account_link }}
                  </div>
                {%- endif -%}

                <div class="drawer-menu__main-nav">
                  <ul class="drawer-menu__primary-links" data-depth="0" data-primary-container="true">
                    {% render 'drawer-menu-list',
                      links: links,
                      mobile_menu_image_blocks: mobile_menu_image_blocks,
                      has_mobile_menu_images: has_first_level_mobile_menu_images,
                      mobile_menu_image_aspect_ratio: mobile_menu_image_aspect_ratio,
                      mobile_menu_image_width: mobile_menu_image_width,
                      mobile_menu_image_link_handles: mobile_menu_image_link_handles,
                      featured_link_label: section.settings.featured_link_label,
                      second_level_mobile_menu_image_link_handles: second_level_mobile_menu_image_link_handles,
                      enable_expand_first: enable_expand_first,
                      blocks: section.blocks
                    %}
                    {%- if sub_links != blank -%}
                      {% render 'drawer-menu-list', links: sub_links, blocks: section.blocks %}
                    {%- endif -%}
                  </ul>
                </div>

                {{ featured_banner }}

                <div class="drawer-menu__wrapper-buttons">
                  {%- if location_button != blank -%}
                    {{- location_button -}}
                  {%- endif -%}

                  {%- if account_placement == 'bottom' -%}
                    {{ account_link }}
                  {%- endif -%}
                </div>

                {% if secondary_links %}
                  <div class="drawer-menu__sub-nav">
                    <div class="" data-tertiary-container="true">
                      <ul
                        class="drawer-menu__sub-links"
                        data-depth="0"
                        data-secondary-container="true"
                        style="--item-height: 42px"
                      >
                        {%- for link in secondary_links -%}
                          <li>
                            <a href="{{ link.url }}" class="underline underline-offset-[3px] ff-body fs-body-75">{{ link.title }}</a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    </div>
                  </div>
                {% endif %}

                {% if localization_dropdowns != blank %}
                  <div class="mt-5">
                    {{ localization_dropdowns }}
                  </div>
                {% endif %}

                {%- if social_icons_mobile -%}
                  <div class="mt-10">{{ social_icons_mobile }}</div>
                {%- endif -%}
              </div>
            </div>
          </div>
          {% if bottom_links.size > 0 or bottom_content != blank %}
            <div class="w-full mt-auto">
              <div class="w-full mt-[30px] bg-black bg-opacity-20 flex flex-col items-center p-8 pt-5">
                {%- if bottom_links.size > 0 -%}
                  <ul class="flex gap-5 justify-center !mb-[14px]">
                    {% for link in bottom_links %}
                      <li class="font-semibold text-[12px] leading-[1.2]">
                        <a href="{{ link.url }}">{{ link.title }}</a>
                      </li>
                    {% endfor %}
                  </ul>
                {%- endif -%}
                {%- if bottom_image != blank -%}
                  {%-
                    render 'image' with
                    wrapper_class: 'max-w-[22px]',
                    image: bottom_image,
                    sizes: '22px',
                    fetch_priority: 'low'
                  -%}
                {%- endif -%}
                {%- if bottom_content != blank -%}
                  <div class="wysiwyg wysiwyg--header mt-2 [&_p]:label-small [&_a]:underline">{{ bottom_content }}</div>
                {%- endif -%}
              </div>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>
