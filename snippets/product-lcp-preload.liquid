{%- comment -%}
  Preload the initially selected product media image so product pages do not
  wait for the gallery markup before the LCP candidate is discovered.
{%- endcomment -%}

{%- liquid
  assign product_lcp_image = blank

  if request.page_type == 'product'
    assign current_variant = product.selected_or_first_available_variant
    assign product_lcp_image = current_variant.featured_media.preview_image | default: product.featured_media.preview_image | default: product.featured_image
  endif
-%}

{%- if product_lcp_image != blank -%}
  <link
    rel="preload"
    as="image"
    href="{{ product_lcp_image | image_url: width: 1200 }}"
    imagesrcset="
      {{ product_lcp_image | image_url: width: 700 }} 700w,
      {{ product_lcp_image | image_url: width: 750 }} 750w,
      {{ product_lcp_image | image_url: width: 800 }} 800w,
      {{ product_lcp_image | image_url: width: 850 }} 850w,
      {{ product_lcp_image | image_url: width: 1000 }} 1000w,
      {{ product_lcp_image | image_url: width: 1200 }} 1200w,
      {{ product_lcp_image | image_url: width: 1400 }} 1400w,
      {{ product_lcp_image | image_url: width: 1600 }} 1600w,
      {{ product_lcp_image | image_url: width: 1800 }} 1800w,
      {{ product_lcp_image | image_url: width: 2000 }} 2000w,
      {{ product_lcp_image | image_url: width: 2200 }} 2200w,
      {{ product_lcp_image | image_url: width: 2400 }} 2400w
    "
    imagesizes="(max-width: 719px) 90vw, 64vw"
    fetchpriority="high"
  >
{%- endif -%}
