{%- capture content -%}
  <div
    class="quick-view-modal-loading-indicator"
    role="status"
    aria-live="polite"
  >
    <span class="visually-hidden">{{ 'general.accessibility.loading' | t }}</span>
    {% render 'loader' %}
  </div>
{%- endcapture -%}
{% render 'quick-view-modal-base' with content: content, open: false %}
