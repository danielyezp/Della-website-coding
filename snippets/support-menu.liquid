{%- if links.size > 0 -%}
    <support-menu class="support-menu block absolute bg-white h-[50px] bottom-0 left-0 z-[-2] top-full text-white w-full {{ class }}">
      <ul class="support-menu__list w-full h-full flex items-center gap-5 px-5 md:gap-8 overflow-hidden overflow-x-auto md:overflow-visible">
        {% for link in links %}
          {% assign show_meganav = false %}
          {% if blocks.size > 0 %}
            {% for block in blocks %}
              {% assign meganav_trigger_handle = block.settings.dropdown_parent_link | handle | strip %}
              {% if link.handle == meganav_trigger_handle and link.links.size > 0 and block.type == 'compact_meganav' %}
                {% assign show_meganav = true %}
                {% assign meganav_settings = block.settings %}
                {% assign meganav_shopify_attributes = block.shopify_attributes %}
              {% endif %}
            {% endfor %}
          {% endif %}
  
          <li class="support-menu__item h-full inline-flex items-center first:m-0 first:ml-auto last:mr-auto
            {% if link.links.size > 0 %}
              js-parent-menu relative
            {% endif %}
          ">
            <a class="js-heading support-menu__item-heading h-full flex items-center gap-1 text-white cursor-pointer" href="{{ link.url }}">
              <span class="support-menu__item-link h5 flex items-center whitespace-nowrap text-black font-semibold text-base">
                <span class="link-hover">{{ link.title }}</span>
              </span>
              {% if link.links.size > 0 %}
                {% render 'icon' with icon: 'chevron-small', class: "navigation__submenu-icon text-black hidden md:block" %}
              {% endif %}
            </a>
            {% if link.links.size > 0 %}
              <div class="js-submenu hidden absolute top-full left-0 text-black bg-white
                min-w-[200px] max-w-[calc(100vw-var(--left-position)-var(--space-outer))]
                invisible opacity-0 [&.active]:visible [&.active]:opacity-100 transition-all z-20
                md:flex border border-solid border-white border-t-0"
                style="
                  --columns-width: {{ meganav_settings.columns_width }}px;
                  --secondary-width: {{ meganav_settings.promo_width }}px;
                  --color-promo-text: {{ meganav_settings.text_color }};
                  --color-text-overlay-button: {{ meganav_settings.text_color }};
                  --color-background-overlay-button: {{ meganav_settings.text_color }};
                  --color-background-overlay-outline-button-alpha:
                  {{ meganav_settings.text_color | color_modify: 'alpha', 0.1 }};
                  --overlay-background: {{ meganav_settings.color_overlay }};
                  {% if meganav_settings.color_overlay_gradient != blank %}
                    --overlay-background-gradient: {{ meganav_settings.color_overlay_gradient }};
                  {% endif %}
                  --overlay-opacity: {{ meganav_settings.overlay_opacity | divided_by: 100.0 }};
                "
              >
                <ul class="flex flex-col gap-4 w-[var(--columns-width)] p-[30px]">
                  {% for link in link.links %}
                    <li>
                      <a class="support-menu__sub-item-link h5 text-black-1 font-semibold text-base" href="{{ link.url }}">
                        <span class="link-hover">{{ link.title }}</span>
                      </a>
                    </li>
                  {% endfor %}
                </ul>
                {%- if show_meganav and meganav_settings.show_promo -%}
                  <div class="w-[var(--secondary-width)] relative">
                    {%- if meganav_settings.link != blank -%}
                      <a href="{{ meganav_settings.link }}" class="meganav__promo-image-link">
                      </a>
                    {%- endif -%}
                    {%- render 'image' with
                      wrapper_class: "relative h-full",
                      image: meganav_settings.image,
                      sizes_px: meganav_settings.promo_width,
                      focal_point: meganav_settings.focal_point,
                      include_placeholder: true,
                      aspect_ratio: "externally_set"
                    -%}
                    <div class="absolute inset-0 bg-[var(--overlay-background)] opacity-[var(--overlay-opacity)]"></div>
                    <div class="absolute inset-0 py-4 px-7 flex flex-col justify-end gap-3 [&_*]:text-white">
                      {% unless meganav_settings.promo_text == blank %}
                        <h3 class="h4">{{ meganav_settings.promo_text }}</h3>
                      {% endunless %}
                      {% if meganav_settings.link and meganav_settings.link != blank %}
                        {%- render 'button-block' with
                          wrapper_class: "mt-3",
                          label: meganav_settings.link_text,
                          link: meganav_settings.link,
                          button_style: 'btn--callout btn--callout-white',
                          is_overlay: true,
                          is_x_small: true,
                          allow_linkless: true,
                        -%}
                      {% endif %}
                    </div>
                  </div>
                {%- endif -%}
              </div>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </support-menu>
  {%- endif -%}