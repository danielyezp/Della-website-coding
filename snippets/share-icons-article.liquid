{%- comment -%}
  Pass in:
  title:String
    - title of product or article, ie. shop.name or article.title
  url:String
    - absolute url of product or article
  image:String
    - url of image to share
{%- endcomment -%}

<div class="share-icons-article" data-share="{{ 'product.share' | t }}">
  <span class="share-icons-article__share fs-body-50 ff-body">{{ 'general.social.share' | t }}</span>
  <div class="share-icons-article__list">
    <a
      target="_blank"
      rel="noopener"
      class="share-icons-article__link"
      href="//twitter.com/share?text={{ title | url_param_escape }}&amp;url={{ url | prepend: shop.domain }}"
    >
      {% render 'icon', icon: 'twitter', view_box_custom: '0 0 24 24' %}
      <span class="sr-only share-icons-article__label">{{ 'general.social.alt_text.share_on_twitter' | t }}</span>
    </a>
    <a
      target="_blank"
      rel="noopener"
      class="share-icons-article__link"
      href="//www.facebook.com/sharer.php?u={{ url | prepend: shop.domain }}"
    >
      {% render 'icon', icon: 'facebook', view_box_custom: '0 0 8 15' %}
      <span class="sr-only share-icons-article__label">{{ 'general.social.alt_text.share_on_facebook' | t }}</span>
    </a>
    <a
      target="_blank"
      rel="noopener"
      class="share-icons-article__link"
      href="mailto:?subject={{ title | url_param_escape }}&body=Check out this article: {{ url | prepend: shop.domain | url_param_escape }}"
    >
      {% render 'icon', icon: 'email', view_box_custom: '0 0 18 13' %}
      <span class="sr-only share-icons-article__label">{{ 'general.social.alt_text.share_on_email' | t }}</span>
    </a>
  </div>
</div>