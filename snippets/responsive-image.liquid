{%- comment -%}
  Pass these variables into snippet:

  Required:

  * image: Image object
  * mobile_image: Image object
  * sizes: srcset size attribute

  Optional:
  * prioritize_loading: is this image rendered above the fold or otherwise prioritized? this will avoid loading="lazy"
  * fetch_priority: optional explicit fetchpriority value (for example "high", "low", or "auto")
  * fallback_width: width shown to browsers that don't support srcSet
  * tag_name: render something other than an `img` element, for instance `picture` or `source`
  * media: custom media definition for `source`
  * aspect_ratio: necessary if the image is displayed at a non natural aspect ratio
  * fallback_alt: fall back alt text if non set on image in admin
  * no_crop: { Boolean } If 'true', the image will be loaded in full, and then cropped in CSS (rather than
      letting Shopify serve a cropped image).
  * src_set_type: optional parameter used to reduce the srcset generation to speed up page perf
      - 'grid'
      - 'full-width'
      - 'thumbnail'
      - if unset a comprehensive src set range will be used
{%- endcomment -%}

{%- liquid
  assign breakpoint_mobile = breakpoint_mobile | default: '719px'

  if mobile_image != blank
    assign tag_name = 'picture'
  endif

  if tag_name == blank or tag_name == "picture"
    assign tag_name_alt = "img"
  else
    assign tag_name_alt = tag_name
  endif

  if fallback_width == blank
    assign fallback_width = 320
  endif

  assign fetch_priority = fetch_priority | default: '' | strip
  if fetch_priority == blank and prioritize_loading
    assign fetch_priority = 'high'
  endif

  if lazy
    assign src_attr = "data-src"
    assign src_set_attr = "data-srcset"
  else
    assign src_attr = "src"
    assign src_set_attr = "srcset"
  endif

  case src_set_type
    when "grid"
      # Assumption: even with a 2-per row grid on large screen, grid item will not be more than 700px @2x wide
      assign src_set_widths_raw = "150,200,240,280,300,360,400,450,500,550,600,650,700,750,800,850,900,950,1000,1100,1200,1300,1400"
    when "full-width"
      # Assumption: even smallest phone will be  350px @ 2x = 700 at least
      assign src_set_widths_raw = "700,850,1000,1200,1400,1600,1800,2000,2200,2400,2800,3200,3840"
    when "thumbnail"
      # Assumption: even desktop thumbnails shouldn't be more 300px @2x wide = 600 max
      assign src_set_widths_raw = "150,200,240,280,300,360,400,450,500,550,600"
    else
      assign src_set_widths_raw = "100,150,200,240,280,300,360,400,450,500,550,600,650,700,750,800,850,900,1000,1100,1200,1400,1600,1800,2000,2200,2400"
  endcase

  assign src_set_widths = src_set_widths_raw | split: ','
  assign src_set_string = ""
  assign mobile_src_set_widths = "150,200,240,280,300,360,400,450,500,550,600,650,700,750,800,850" | split: ','
  assign mobile_src_set_string = ""

  if fetch_priority == blank and prioritize_loading != true
    assign fetch_priority = 'low'
  endif
-%}

{%- liquid
  if object_fit != "contain" and aspect_ratio != blank and aspect_ratio != 'natural'
    case aspect_ratio
      when "portrait"
        assign crop_height_ratio = 1.5
      when "landscape"
        assign crop_height_ratio = 0.666666
      when "square"
        assign crop_height_ratio = 1
      when "portrait_alt"
        assign crop_height_ratio = 1.25
      when "landscape_alt"
        assign crop_height_ratio = 0.8
      when "landscape_wide_alt"
        assign crop_height_ratio = 0.5625
    endcase
  endif

  assign image_crop = "center"
  if focal_alignment != blank and focal_alignment != "center"
    assign image_crop = focal_alignment
  endif
-%}

{%- for width_string in src_set_widths -%}
  {%- assign width = width_string | plus: 0 -%}

  {% if image.width < width %}
    {% break %}
  {% endif %}

  {%- if crop_height_ratio and focal_point != "image_presentation" -%}
    {%- assign crop_height = width | times : crop_height_ratio -%}
    {%- if image.height < crop_height -%}
      {% break %}
    {%- endif -%}
  {%- endif -%}

  {%- capture src_set_string -%}
    {%- if src_set_string.size > 0 -%}{{ src_set_string }},{{ ' ' }}{%- endif -%}
    {%- if crop_height_ratio and focal_point != "image_presentation" and no_crop != true -%}
      {{ image | image_url: width: width, height: crop_height, crop: image_crop }} {{width}}w
    {%- else -%}
      {{ image | image_url: width: width }} {{width}}w
    {%- endif -%}
  {%- endcapture -%}
{%- endfor -%}

{%- if mobile_image != blank -%}
  {%- assign mobile_focal_point = mobile_focal_point | default: focal_point -%}
  {%- for width_string in mobile_src_set_widths -%}
    {%- assign width = width_string | plus: 0 -%}

    {% if mobile_image.width < width %}
      {% break %}
    {% endif %}

    {%- if crop_height_ratio and mobile_focal_point != "image_presentation" -%}
      {%- assign crop_height = width | times : crop_height_ratio -%}
      {%- if mobile_image.height < crop_height -%}
        {% break %}
      {%- endif -%}
    {%- endif -%}

    {%- capture mobile_src_set_string -%}
      {%- if mobile_src_set_string.size > 0 -%}{{ mobile_src_set_string }},{{ ' ' }}{%- endif -%}
      {%- if crop_height_ratio and mobile_focal_point != "image_presentation" and no_crop != true -%}
        {{ mobile_image | image_url: width: width, height: crop_height, crop: image_crop }} {{width}}w
      {%- else -%}
        {{ mobile_image | image_url: width: width }} {{width}}w
      {%- endif -%}
    {%- endcapture -%}
  {%- endfor -%}
  {%- if mobile_src_set_string == blank -%}
    {%- assign mobile_src_set_string = mobile_image | image_url: width: mobile_image.width | append: ' ' | append: mobile_image.width | append: 'w' -%}
  {%- endif -%}
{%- endif -%}

{% capture alt %}{% if image.alt.size > 0 %}{{ image.alt }}{% else %}{{ fallback_alt }}{% endif %}{% endcapture %}

{%- if tag_name == 'picture' -%}
<picture>
  {%- if mobile_src_set_string != blank -%}
    <source
      media="(max-width: {{ breakpoint_mobile }})"
      {{ src_set_attr }}="{{ mobile_src_set_string }}"
      sizes="{{ mobile_sizes | default: sizes }}"
    />
  {%- endif -%}
{%- endif -%}

<{{ tag_name_alt }}
  alt="{{ alt | escape }}"{{ ' ' }}
  class="image__img{%- if class_name -%} {{ class_name }}{%- endif -%}"{{ ' ' }}
  {% unless prioritize_loading %}loading="lazy"{{ ' ' }}{% endunless %}
  {% unless prioritize_loading %}decoding="async"{{ ' ' }}{% endunless %}
  {% if tag_name_alt != 'source' and fetch_priority != blank %}fetchpriority="{{ fetch_priority }}"{{ ' ' }}{% endif %}
  width="{{ image.width }}"{{ ' ' }}
  height="{{ image.height }}"{{ ' ' }}
  {% unless tag_name == "source" %}{{ src_attr }}="{{ image | image_url: width: fallback_width }}"{{ ' ' }}{% endunless %}
  {% if media %}media="{{ media }}"{{ ' ' }}{% endif %}
  {{ src_set_attr }}="{{ src_set_string }}"{{ ' ' }}
  sizes="{{ sizes }}"
  onload="javascript: this.closest('.image').classList.add('loaded')"
/>
{%- if tag_name == 'picture' -%}
  </picture>
{%- endif -%}
