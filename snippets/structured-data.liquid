      "headline": "{{- page.title -}}",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "url": "{{- shop.url -}}{{- page.url -}}"
      },
      "publisher": {
        "@type": "Organization",
        "name": "{{- shop.name -}}",
        "logo": {
          "@type": "ImageObject",
          "url": "{{ structured_logo_url }}"
        }
      },
      "url": "{{ shop.url }}{{- page.url -}}"
    }
  </script>
{%- elsif template contains 'blog' -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org/",
      "@type": "Blog",
      "@id": "{{ shop.url }}{{- blog.url -}}",
      "mainEntityOfPage": "{{ shop.url }}{{- blog.url -}}",
      "name": {{ blog.title | json }},
      "description": "{{ blog.description | strip_html | escape }}",
      {% unless request.path contains '/tagged/' -%}
        "blogPost": [
          {%- for article in blog.articles -%}
            {%- liquid
              assign article_title = article.title | strip_html | strip_newlines | escape
              assign article_description = page_description
              if article.excerpt != blank
                assign article_description = article.excerpt | strip_html | strip_newlines | escape
              endif
              assign youtube_video_link = article.metafields.bbf.youtube_video_link
              capture youtube_video_id
                render 'youtube-video-id', youtube_video_link: youtube_video_link
              endcapture
              assign image_metafield = article.metafields.bbf.hero_image
              if image_metafield != blank
                assign article_image = image_metafield
              elsif youtube_video_id != blank
                assign youtube_video_id_strip = youtube_video_id | strip
                assign article_image = "https://img.youtube.com/vi/youtube_video_id_strip/hqdefault.jpg" | replace: "youtube_video_id_strip", youtube_video_id_strip
              else
                assign article_image = article.image | image_url: width: article.image.width | prepend: 'https:'
              endif
            -%}
            {
              "@type": "BlogPosting",
              "@id": "{{ shop.url }}{{- article.url -}}",
              "mainEntityOfPage": "{{ shop.url }}{{- article.url -}}",
              "headline": "{{ article_title }}",
              "name": "{{ article_title }}",
              "description": "{{ article_description }}",
              "datePublished": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%:z' }}",
              "dateModified": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%:z' }}",
              "author": {
                  "@type": "Person",
                  "@id": "{{ shop.url }}{{- article.url -}}/#{{article.author}}",
                  "url": "{{ shop.url }}{{- article.url -}}/#{{article.author}}",
                  "name": {{- article.author | json -}}
              },
              "image": {
                "@type": "ImageObject",
                "@id": "{{ article_image }}",
                "url": "{{ article_image }}"
              },
              "url": "{{- shop.url -}}{{- article.url -}}",
              "keywords": "{{ article.tags | join: ', ' }}"
            }
            {% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        ],
      {%- endunless %}
      "publisher": {
        "@type": "Organization",
        "@id": "https://dataliberate.com",
        "name": "Data Liberate",
        "logo": {
          "@type": "ImageObject",
          "url": "{{ structured_logo_url }}"
        }
      }
    }
  </script>
{%- endif -%}
