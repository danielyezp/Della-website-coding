{%- liquid
  assign all_rebates_skus = ''

  for variant in product.variants
    assign variant_identifier = variant.sku | default: variant.barcode | strip

    if variant_identifier != blank
      if all_rebates_skus != blank
        assign all_rebates_skus = all_rebates_skus | append: ','
      endif
      assign all_rebates_skus = all_rebates_skus | append: variant_identifier
    endif
  endfor

  assign combine_listing_products = product.metafields.custom.combine_listing_product.value
  if combine_listing_products != blank
    for combined_product in combine_listing_products
      for variant in combined_product.variants
        assign variant_identifier = variant.sku | default: variant.barcode | strip

        if variant_identifier != blank
          if all_rebates_skus != blank
            assign all_rebates_skus = all_rebates_skus | append: ','
          endif
          assign all_rebates_skus = all_rebates_skus | append: variant_identifier
        endif
      endfor
    endfor
  endif

  assign rebates_skus = all_rebates_skus | strip
  assign widget_script_url = 'https://static.ecorebates.com/widgets/dellahome/product.js'
-%}

{%- if rebates_skus != blank and product.metafields.custom.hide_ecorebates != true -%}
  {%- if widget_script_url != blank -%}
    <script src="{{ widget_script_url | escape }}" async></script>
  {%- endif -%}

  {{- '<!-- eco rebates: widget hidden, JS injects badge into specs ul or shows fallback -->' -}}

  <span style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap" aria-hidden="true">
    <ecr-product-widget skus="{{ rebates_skus | escape }}" uiContext="PLP">
      <div slot="open-details" style="display:none;">
        <span>{{ 'sections.tech_specs.rebate_available' | t }}</span>
      </div>
    </ecr-product-widget>
  </span>

  <div data-eco-rebate-fallback class="rte rte--product-tech-specs ff-body fs-body-50" style="display:none">
    <div class="product-tech-specs-layout">
      <div class="product-tech-specs-layout__content">
        <ul>
          <li>
            <span class="product-tech-specs-layout__rebate">
              {{ 'sections.tech_specs.rebate_available' | t }}
              <img
                src="{{ 'rebate-available.png' | asset_url }}"
                alt=""
                width="21"
                height="21"
                loading="lazy"
              >
            </span>
          </li>
        </ul>
      </div>
    </div>
  </div>
{%- endif -%}
