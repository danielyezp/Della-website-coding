{%- liquid
  assign settings = block.settings
  assign heading = settings.title
  assign text = settings.text
  assign is_first = forloop.first
-%}

<div
  class="collapsible-row-list-item collapsible-row-image-item"
  data-block-id="{{ block.id }}"
  data-index="{{ forloop.index0 }}"
  {{ block.shopify_attributes }}
>
  {%- unless heading == blank -%}
    <button
      type="button"
      class="collapsible-row-list-item__trigger collapsible-row-image-item__trigger {% if item_heading_font == 'heading' %}ff-heading fs-heading-5-base{% elsif item_heading_font == 'subheading' %}ff-subheading fs-body-200{% else %}ff-body fs-body-250{% endif %}"
      {% if text != blank %}
        aria-controls="content-{{ block.id }}"
        aria-expanded="{{ is_first }}"
        data-accordion-trigger
      {% else %}
        data-flash-trigger
        data-flash-message="{{ 'general.flash_alert.no_text' | t }}"
      {% endif %}
    >
      {%- if block.settings.custom_icon_image != blank -%}
        {%-
          render 'image' with
          wrapper_class: "collapsible-row-list-item__icon",
          image: block.settings.custom_icon_image,
          sizes: "25px",
        -%}
      {%- else -%}
        {% if block.settings.icon != 'none' %}
          {% render 'icon-editorial' with class: "collapsible-row-list-item__icon", icon: block.settings.icon %}
        {% endif %}
      {%- endif -%}
      <span class="collapsible-row-list-item__heading">
        {{ heading }}
      </span>
      <div class="accordion__label-icons">
        {% render 'icon', with icon: 'plus' %}
        {% render 'icon', with icon: 'minus' %}
      </div>
    </button>
  {%- endunless -%}

  {%- unless text == blank -%}
    <div
      class="collapsible-row-list-item__text-container"
      {% if heading != blank %}
        aria-hidden="{% if is_first %}false{% else %}true{% endif %}"
        id="content-{{ block.id }}"
      {% endif %}
    >
      <div class="collapsible-row-list-item__text fs-body-50 rte">
        {{ text }}
      </div>
      {%- if block.settings.video != blank -%}
        <div class="collapsible-row-list-item__video">
          <video-control class="collapsible-row-list-item__video">
            <div class="collapsible-row-list-item__video-wrapper">
              {{
                block.settings.video
                | video_tag: muted: true, loop: true, controls: false, image_size: '720x', preload: 'metadata'
                | replace: '<video', '<video class="collapsible-row-list-item__video-element js-video"'
              }}
              <div class="collapsible-row-image__video-controls">
                <button class="collapsible-row-image__video-toggle video-play-button js-button-video" type="button" aria-label="{{ 'general.accessibility.play' | t }}" aria-pressed="false">
                  <span class="video-button-content video-button-content--play">
                    {%- render 'play-icon', class: 'collapsible-row-image__video-toggle-icon' -%}
                    <span class="sr-only">{{ 'general.accessibility.play' | t }}</span>
                  </span>
                  <span class="video-button-content video-button-content--pause">
                    {%- render 'pause-icon', class: 'collapsible-row-image__video-toggle-icon' -%}
                    <span class="sr-only">{{ 'general.accessibility.pause' | t }}</span>
                  </span>
                </button>
              </div>
            </div>
          </video-control>
        </div>
      {%- elsif block.settings.image != blank -%}
        <div class="collapsible-row-list-item__image">
          {{ block.settings.image | image_url: width: 1000 | image_tag }}
        </div>
      {%- endif -%}
    </div>
  {%- endunless -%}
</div>
