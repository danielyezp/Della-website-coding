{%- assign filtered_block_count = 0 -%}
{%- assign has_media = false -%}
{%- for block in section.blocks -%}
  {%- if block.settings.text != blank or request.design_mode -%}
    {%- assign filtered_block_count = filtered_block_count | plus: 1 -%}
    {%- if block.settings.video != blank or block.settings.image != blank -%}
      {%- assign has_media = true -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

{%- capture row_list_content -%}
  {%- for block in section.blocks -%}
    {%- if block.settings.text != blank or request.design_mode -%}
      {%- render 'collapsible-row-image-item',
        block: block,
        item_heading_font: section.settings.item_heading_font,
        forloop: forloop
      -%}
    {%- endif -%}
  {%- endfor -%}
{%- endcapture -%}

{%- liquid
  assign has_section_background = false
  if section.settings.section_background_color != blank and section.settings.section_background_color != 'rgba(0,0,0,0)'
    assign has_section_background = true
  endif

  assign media_aspect_ratio_css = '32 / 35'
  if section.settings.media_aspect_ratio == 'square'
    assign media_aspect_ratio_css = '1 / 1'
  endif
-%}

{%- if filtered_block_count > 0 -%}
  <div
    class="
      collapsible-row-image
      {% unless has_media %}collapsible-row-image--no-media{% endunless %}
      {% if settings.enable_section_animations and section.settings.enable_animation %}
        animation
        animation--collapsible-row-image
      {% endif %}
      link-color-scheme--{{ section.settings.link_color_scheme }}
    "
    data-section-id="{{ section.id }}"
    data-section-type="collapsible-row-image"
    style="
      --heading-alignment: {{ section.settings.heading_alignment }};
      --collapsible-row-image-media-aspect-ratio: {{ media_aspect_ratio_css }};
      {% if section.settings.content_width == 'custom' %}
        --content-width: {{ section.settings.custom_content_width }}px;
      {% endif %}
      {% if has_section_background %}
        background-color: {{ section.settings.section_background_color }};
      {% endif %}
    "
  >
    <div class="section section--large-gaps section--divider-{{ section.settings.divider_style }} {{ section.settings.section_padding }}">
      <div class="collapsible-row-image__inner">
        <div class="collapsible-row-image__list">
          {%- if section.settings.subheading != blank -%}
            <{{ section.settings.subheading_tag }} class="collapsible-row-image__subheading ff-subheading {{ section.settings.subheading_font_class }} {{ section.settings.subheading_color }} section-blocks__subheading">
              {{ section.settings.subheading }}
            </{{ section.settings.subheading_tag }}>
          {%- endif -%}

          {%- if section.settings.title != blank -%}
            <{{ section.settings.heading_tag }} class="collapsible-row-image__heading ff-heading {{ section.settings.heading_font_class }} {{ section.settings.heading_color }}">
              {{ section.settings.title }}
            </{{ section.settings.heading_tag }}>
          {%- endif -%}

          <div class="collapsible-row-image__accordion">
            {{ row_list_content }}
          </div>
        </div>

        {%- if has_media -%}
          <div class="collapsible-row-image__media">
            {%- assign first_filtered_media = true -%}
            {%- for block in section.blocks -%}
              {%- if block.settings.text != blank or request.design_mode -%}
                {%- liquid
                  assign block_video = block.settings.video
                  assign block_image = block.settings.image
                -%}
                {%- if block_video != blank or block_image != blank -%}
                  <div
                    class="collapsible-row-image__media-item {% if first_filtered_media %}collapsible-row-image__media-item--active{% endif %}"
                    data-block-id="{{ block.id }}"
                    data-media-panel
                    aria-hidden="{% if first_filtered_media %}false{% else %}true{% endif %}"
                    {% unless first_filtered_media %}inert{% endunless %}
                  >
                  {%- if block_video != blank -%}
                    <video-control class="collapsible-row-image__video">
                      <div class="collapsible-row-image__video-wrapper">
                        {{
                          block_video
                          | video_tag: muted: true, loop: true, controls: false, image_size: '720x', preload: 'metadata'
                          | replace: '<video', '<video class="collapsible-row-image__video-element js-video"'
                        }}
                        <div class="collapsible-row-image__video-controls">
                          <button class="collapsible-row-image__video-toggle video-play-button js-button-video" type="button" aria-label="{{ 'general.accessibility.play' | t }}" aria-pressed="false">
                            <span class="video-button-content video-button-content--play">
                              {%- render 'play-icon', class: 'collapsible-row-image__video-toggle-icon' -%}
                              <span class="sr-only">{{ 'general.accessibility.play' | t }}</span>
                            </span>
                            <span class="video-button-content video-button-content--pause">
                              {%- render 'pause-icon', class: 'collapsible-row-image__video-toggle-icon' -%}
                              <span class="sr-only">{{ 'general.accessibility.pause' | t }}</span>
                            </span>
                          </button>
                        </div>
                      </div>
                    </video-control>
                  {%- elsif block_image != blank -%}
                    <div class="collapsible-row-image__image">
                      {%- render 'image' with
                        image: block_image,
                        sizes: '(min-width: 960px) 50vw, 100vw',
                        wrapper_class: 'collapsible-row-image__image-wrapper'
                      -%}
                    </div>
                  {%- endif -%}
                  </div>
                  {%- assign first_filtered_media = false -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
{%- endif -%}

{%- liquid
  assign has_faq_schema_entries = false
  if filtered_block_count > 0
    for block in section.blocks
      assign faq_question = block.settings.title | strip
      assign faq_answer = block.settings.text | strip_html | strip
      if faq_question != blank and faq_answer != blank
        assign has_faq_schema_entries = true
        break
      endif
    endfor
  endif
-%}

{%- if has_faq_schema_entries -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {%- assign faq_has_previous_item = false -%}
        {%- for block in section.blocks -%}
          {%- assign faq_question = block.settings.title | strip -%}
          {%- assign faq_answer = block.settings.text | strip_html | strip -%}
          {%- if faq_question != blank and faq_answer != blank -%}
            {%- if faq_has_previous_item -%},{%- endif -%}
            {
              "@type": "Question",
              "name": {{ faq_question | json }},
              "acceptedAnswer": {
                "@type": "Answer",
                "text": {{ faq_answer | json }}
              }
            }
            {%- assign faq_has_previous_item = true -%}
          {%- endif -%}
        {%- endfor -%}
      ]
    }
  </script>
{%- endif -%}

