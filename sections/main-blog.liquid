{%- render 'asset' with 'template-blog.css' -%}

{%- liquid
  assign paginate_by = section.settings.article_per_page
  assign article_categories = settings.article_categories | downcase

  assign has_featured_card = false

  if section.settings.card_background != blank
    assign has_featured_card = true
    assign position_value = section.settings.card_position | default: 4
    assign position = position_value | times: 1
    assign paginate_by = paginate_by | minus: 1
  endif
  assign has_featured = section.settings.show_featured_item
  assign post_column = section.settings.post_column
-%}

{%- if section.settings.show_tag_nav and blog.all_tags.size > 0 -%}
  {%- for tag in blog.all_tags -%}
    {%- assign tag_dc = tag | downcase -%}
    {%- if article_categories contains tag_dc or article_categories == blank -%}
      {%- capture tag_list -%}
        {{ tag_list }}
        <li class="blog__nav-item">
          <a
            href="{{ blog.url }}/tagged/{{ tag | handle }}"
            class="
              blog__nav-link btn btn--text-link animation--item ff-subheading fs-body-200
              {% if current_tags contains tag %} blog__nav-link--active{% endif %}
            "
          >
            {{ tag }}
          </a>
        </li>
      {%- endcapture -%}
      {%- capture tag_select_options -%}
        {{ tag_select_options }}
        <option
          value="{{ blog.url }}/tagged/{{ tag | handle }}"
          {% if current_tags contains tag %}
            selected="selected"
          {% endif %}
        >
          {{ tag }}
        </option>
      {%- endcapture -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{% paginate blog.articles by paginate_by %}
  <div
    class="
      blog
      section
      section--large-gaps
      {% if settings.enable_section_animations and section.settings.enable_animation %}
        animation
        animation--blog
      {% endif %}
      link-color-scheme--{{ section.settings.link_color_scheme }}
    "
    data-page="{{ paginate.current_page }}"
    data-section-id="{{ section.id }}"
    data-section-type="blog"
    style="--post_column:{{ post_column }};--article-column: {{ section.settings.article_column }};"
  >
    <div class="blog__inner">
      {%- if tag_list.size > 0 -%}
        <div class="blog__nav">
          <ul class="blog__nav-list" data-current="{{ current_tags }}">
            <li class="blog__nav-item">
              <a
                href="{{ blog.url }}"
                class="
                  blog__nav-link btn btn--text-link animation--item ff-subheading fs-body-200
                  {% if current_tags == blank %} blog__nav-link--active{% endif %}
                "
              >
                {{ 'blogs.general.all' | t }}
              </a>
            </li>
            {{ tag_list }}
          </ul>

          {%- if tag_select_options.size > 0 -%}
            <div class="blog__nav-mobile--wrapper select-wrapper">
              <p class="blog__nav-mobile--label ff-subheading fs-body-300">{{- 'blogs.general.categories' | t -}}</p>
              <select name="blog-mobile-nav" id="blog-mobile-nav" class="blog__nav-mobile input">
                <option
                  value="{{ blog.url }}"
                  {% if current_tags == blank %}
                    selected="selected"
                  {% endif %}
                >
                  {{ 'blogs.general.all' | t }}
                </option>
                {{ tag_select_options }}
              </select>
              {%- render 'icon' with icon: 'arrow-down', view_box_custom: '0 0 15 8' -%}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="blog__articles-wrapper">
        <ul class="blog__article-list">
          {%- for article in blog.articles -%}
            {%- if forloop.index == position and section.settings.card_background != blank -%}
              {% liquid
                assign card_columns = section.settings.card_columns | plus: 0
                assign text_color = section.settings.card_text_color
              %}
              <li class="blog__article-item-cta-card"
                  style="
                    --card-columns: {{ card_columns }};
                    --card-text-color: {{- text_color -}};
                  "
              >
                <div class="blog__article-item-cta-card-inner">
                  {%- render 'image',
                    image: section.settings.card_background,
                    wrapper_class: 'blog__article-item-cta-card-image',
                    object_fit: 'cover',
                    include_placeholder: true,
                    animate: true,
                    sizes: "'(max-width: 720px) calc((90vw - 12px) / 2), (max-width: 1400px) calc((93.4vw - (12px * 3)) / 3), 450px'",
                    src_set_type: "grid"
                  -%}
                  <div class="blog__article-item-cta-card-content">
                    {%- if section.settings.card_headline != blank -%}
                      <h3 class="blog__article-item-cta-card-heading ff-heading fs-heading-4-base">{{- section.settings.card_headline -}}</h3>
                    {%- endif -%}
                    {%- if section.settings.card_text != blank -%}
                      <div class="blog__article-item-cta-card-text rte">{{- section.settings.card_text -}}</div>
                    {%- endif -%}
                    {%- if section.settings.card_button_text != blank and section.settings.card_button_link != blank -%}
                      {%- render 'button-block',
                        wrapper_class: 'blog__article-item-cta-card-button',
                        label: section.settings.card_button_text,
                        link: section.settings.card_button_link,
                        is_full: true
                      -%}
                    {%- endif -%}
                  </div>
                </div>
              </li>
            {%- endif -%}
            <li class="blog__article-item">
              {%
                render 'article-item',
                blog_article: article,
                blog: blog,
                aspect_ratio: section.settings.aspect_ratio,
                show_author: section.settings.show_author,
                show_date: section.settings.show_date,
                show_tags: section.settings.show_tags,
                show_excerpt: section.settings.show_excerpt,
                show_featured_image: section.settings.show_featured_image,
                heading_tag: 'h2'
              %}
            </li>
          {%- endfor -%}
        </ul>

        <div class="blog__pagination animation animation--blog-pagination">
          {% if paginate.pages > 1 %}
            {% render 'pagination', paginate: paginate, type: 'general.pagination.blog_posts' %}
          {% endif %}
        </div>
      </div>
    </div>
  </div>
{% endpaginate %}

{% schema %}
{
  "name": "t:sections.main_blog.name",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_tag_nav",
      "label": "t:sections.main_blog.settings.show_tag_nav.label",
      "default": true
    },
    {
      "type": "range",
      "id": "article_per_page",
      "min": 12,
      "max": 36,
      "step": 12,
      "label": "t:sections.main_blog.settings.article_per_page.label",
      "default": 12
    },
    {
      "type": "select",
      "id": "article_column",
      "label": "t:sections.main_blog.settings.article_column.label",
      "options": [
        {
          "value": "2",
          "label": "t:shared.column.option_2"
        },
        {
          "value": "3",
          "label": "t:shared.column.option_3"
        },
        {
          "value": "4",
          "label": "t:shared.column.option_4"
        }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "t:sections.main_blog.settings.article_options_header.content"
    },
    {
      "id": "show_tags",
      "type": "checkbox",
      "label": "t:sections.main_blog.settings.show_tags.label",
      "info": "t:sections.main_blog.settings.show_tags.info",
      "default": true
    },
    {
      "id": "show_author",
      "type": "checkbox",
      "label": "t:sections.main_blog.settings.show_author.label",
      "default": true
    },
    {
      "id": "show_date",
      "type": "checkbox",
      "label": "t:sections.main_blog.settings.show_date.label",
      "default": true
    },
    {
      "id": "show_excerpt",
      "type": "checkbox",
      "label": "t:sections.main_blog.settings.show_excerpt.label",
      "default": true
    },
    {
      "id": "show_featured_image",
      "type": "checkbox",
      "label": "t:sections.main_blog.settings.show_featured_image.label",
      "default": true
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "t:shared.settings.aspect_ratio.label",
      "default": "landscape",
      "options": [
        {
          "value": "natural",
          "label": "t:shared.settings.aspect_ratio.option_natural"
        },
        {
          "value": "square",
          "label": "t:shared.settings.aspect_ratio.option_square"
        },
        {
          "value": "portrait",
          "label": "t:shared.settings.aspect_ratio.option_portrait"
        },
        {
          "value": "landscape",
          "label": "t:shared.settings.aspect_ratio.option_landscape"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.main_blog.settings.card_header.label"
    },
    {
      "type": "select",
      "id": "card_columns",
      "label": "t:shared.column.name",
      "options": [
        {
          "value": "1",
          "label": "t:shared.column.option_1"
        },
        {
          "value": "2",
          "label": "t:shared.column.option_2"
        }
      ],
      "default": "1"
    },
    {
      "type": "image_picker",
      "id": "card_background",
      "label": "t:sections.main_blog.settings.card_background.label"
    },
    {
      "type": "text",
      "id": "card_headline",
      "label": "t:sections.main_blog.settings.card_headline.label"
    },
    {
      "type": "richtext",
      "id": "card_text",
      "label": "t:sections.main_blog.settings.card_text.label"
    },
    {
      "type": "text",
      "id": "card_button_text",
      "label": "t:sections.main_blog.settings.card_button_text.label"
    },
    {
      "type": "url",
      "id": "card_button_link",
      "label": "t:sections.main_blog.settings.card_button_link.label"
    },
    {
      "type": "text",
      "id": "card_position",
      "label": "t:sections.main_blog.settings.card_position.label",
      "default": "4"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "t:sections.main_blog.settings.card_text_color.label",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "t:shared.settings.section_style.header_style.content"
    },
    {
      "id": "enable_animation",
      "type": "checkbox",
      "label": "t:shared.settings.section_style.enable_animation.label",
      "info": "t:shared.settings.section_style.enable_animation.info",
      "default": true
    },
    {
      "type": "range",
      "id": "post_column",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "t:sections.main_blog.settings.post_column_header.content",
      "default": 2
    },
    {
      "type": "select",
      "id": "link_color_scheme",
      "label": "t:shared.settings.link_color_scheme.label",
      "options": [
        {
          "value": "light",
          "label": "t:shared.settings.link_color_scheme.option_light"
        },
        {
          "value": "dark",
          "label": "t:shared.settings.link_color_scheme.option_dark"
        }
      ],
      "default": "dark"
    }
  ]
}
{% endschema %}