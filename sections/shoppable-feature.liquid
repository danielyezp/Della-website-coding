{%- render 'asset' with '/frontend/styles/modules/component-shoppable.css' -%}
{%- liquid
  assign show_hotspot_cards = false
  assign non_image_half = 100 | minus: section.settings.image_size
  assign non_image_half = non_image_half | divided_by: 100.00
-%}

{%- assign image_sizes_fraction = non_image_half | times: 0.55 -%}
{%- capture image_sizes -%}
  (min-width: 960px) calc(((100vw - (2 * clamp(18px, 3.3vw, 3.3vw))) * {{ image_sizes_fraction }}) - 34px), 160px
{%- endcapture -%}

{%- capture swiper_content -%}
  <div class="shoppable-feature__carousel-outer" role="region" aria-live="polite" data-slide-count="{{ section.blocks.size }}">
    <div class="shoppable-feature__carousel swiper">
      <div class="shoppable-feature__carousel-inner swiper-wrapper">
        {%- for block in section.blocks -%}
          <div
            class="swiper-slide"
            {% unless forloop.first %}
              inert
            {% endunless %}
          >
            {% render 'product-card-mini', prod: block.settings.product_item, index: forloop.index, image_sizes: image_sizes %}
          </div>
        {%- else -%}
          <div
            class="swiper-slide"
            {% unless forloop.first %}
              inert
            {% endunless %}
          >
            {% render 'product-card-mini', placeholder: true, index: forloop.index, image_sizes: image_sizes %}
          </div>
        {%- endfor -%}
      </div>
    </div>
    <button class="slider-nav-button slider-nav-button-prev" title="{{ 'general.accessibility.previous' | t }}">
      {% render 'icon', icon: 'chevron' %}
    </button>
    <button class="slider-nav-button slider-nav-button-next" title="{{ 'general.accessibility.next' | t }}">
      {% render 'icon', icon: 'chevron' %}
    </button>
    <div class="swiper-pagination fs-body-50"></div>
  </div>
{%- endcapture %}

{%- capture text_content -%}
  {%- unless section.settings.heading == blank
    and section.settings.subheading == blank
    and section.settings.link_text == blank
  -%}
    <div class="shoppable-feature__text-block section-introduction animation--section-introduction">
      {%- unless section.settings.heading == blank -%}
        <{{ section.settings.heading_tag }} class="shoppable-feature__heading ff-heading fs-heading-3-base section-introduction__heading {% if section.settings.text_color == 'rgba(0,0,0,0)' or section.settings.text_color == blank %}{{ section.settings.heading_color }}{% endif %}">
          {{ section.settings.heading | newline_to_br }}
        </{{ section.settings.heading_tag }}>
      {%- endunless -%}

      {%- unless section.settings.subheading == blank -%}
        <div class="shoppable-feature__subheading ff-subheading fs-body-100 rte section-introduction__subheading {% if section.settings.text_color == 'rgba(0,0,0,0)' or section.settings.text_color == blank %}{{ section.settings.subheading_color }}{% endif %}">
          {{ section.settings.subheading }}
        </div>
      {%- endunless -%}

      {%- unless section.settings.link_text == blank -%}
        {%-
          render 'button-block',
          wrapper_class: "shoppable-feature__cta-button section-introduction__button",
          link: section.settings.link,
          label: section.settings.link_text,
          button_style: section.settings.button_style
          button_color: section.settings.button_color
        -%}
      {%- endunless -%}
    </div>
  {%- endunless -%}
{%- endcapture -%}
<div
  data-section-id="{{ section.id }}"
  data-section-type="shoppable"
  class="
    shoppable-feature
    shoppable-feature--image-{{ section.settings.image_position }}
    shoppable-feature--mobile-content-position-{{ section.settings.content_position_mobile }}
    section
    section--divider-{{ section.settings.divider_style }}
    {{ section.settings.section_padding }}
    {% if settings.enable_section_animations and section.settings.enable_animation %}
      animation
      animation--shoppable-feature
    {% endif %}
    {% if section.settings.enable_full_width %}
      shoppable-feature--full-width
    {% endif %}
    link-color-scheme--{{ section.settings.link_color_scheme }}
  "
  style="
    --section-text-color: {{ section.settings.text_color }};
    --content-padding-x: {{ section.settings.content_padding_x }}px;
    --content-padding-y: {{ section.settings.content_padding_y }}px;
    --content-padding-x-mobile: {{ section.settings.content_padding_x_mobile }}px;
    --content-padding-y-mobile: {{ section.settings.content_padding_y_mobile }}px;
    --heading-max-width: {{ section.settings.heading_max_width }}px;
    --subheading-max-width: {{ section.settings.subheading_max_width }}px;
  "
  data-show-hotspot-cards="{{ show_hotspot_cards }}"
  data-content-position-desktop="{{ section.settings.content_position_desktop }}"
>
  <div class="section__inner shoppable-feature__inner">
    {%- if section.settings.content_position_mobile == 'above' -%}
      <div class="shoppable-feature__text-block-wrap-external">
        {{ text_content }}
      </div>
    {%- endif -%}
    <div class="shoppable-feature__inner-items">
      <div
        class="shoppable-feature__image-container shoppable__image-container"
        style="--desktop-image-width: {{ section.settings.image_size }}%"
        data-aspect-ratio="{{ section.settings.aspect_ratio }}"
      >
        <div class="shoppable-feature__image-container-inner">
          <div class="shoppable-feature__image-wrapper">
            {% render 'image',
              image: section.settings.image,
              wrapper_class: 'shoppable-feature__image',
              focal_point: 'image_presentation',
              aspect_ratio: section.settings.aspect_ratio,
              sizes: '(min-width: 1500px) 762px, (min-width: 720px) calc(100vw - calc(2 * 3.3vw)), calc(100vw - calc(2 * clamp(18px, 3.3vw, 3.3vw)))',
              placeholder_name: 'collection-4',
              include_placeholder: true,
              animate: true
            %}
          </div>
          {%- unless section.settings.hide_hotspots -%}
            {%- for block in section.blocks -%}
              {%
                render 'shoppable-item',
                block: block,
                index: forloop.index0,
                product_item: block.settings.product_item,
                horizontal_position: block.settings.horizontal_position,
                vertical_position: block.settings.vertical_position,
                aspect_ratio: section.settings.aspect_ratio,
                show_hotspot_cards: show_hotspot_cards,
              %}
            {%- endfor -%}
          {%- endunless -%}
        </div>
      </div>

      <div class="shoppable-feature__secondary-content" data-hide-hotspots="{{ section.settings.hide_hotspots | json }}">
        {%- if section.settings.background_image != blank -%}
          {{ section.settings.background_image | image_url: width: section.settings.background_image.width | image_tag: widths: '300,400,500,600,700,800,900,1000,1200,1400,1600', sizes: '(min-width: 720px) 50vw, 100vw', class: 'shoppable-feature__background-image' }}
        {%- endif -%}
        <div class="shoppable-feature__text-block-wrap-internal">
          {{ text_content }}
        </div>
        {{ swiper_content }}
      </div>
    </div>
  </div>
  {%- unless section.settings.hide_hotspots -%}
    {%- render 'mobile-drawer',
      class: 'shoppable-feature-mobile-drawer animation--shoppable-feature-mobile-drawer',
      content: swiper_content
    -%}
  {%- endunless -%}
</div>

{% schema %}
{
  "name": "t:sections.shoppable_feature.name",
  "tag": "section",
  "disabled_on": {
    "groups": [
      "header",
      "custom.overlay"
    ],
    "templates": [
      "password"
    ]
  },
  "settings": [
    {
      "id": "background_image",
      "type": "image_picker",
      "label": "t:sections.shoppable_feature.settings.background_image.label"
    },
    {
      "id": "image",
      "type": "image_picker",
      "label": "t:sections.shoppable_feature.settings.image.label"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "t:sections.shoppable_feature.settings.image_position.label",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "t:sections.shoppable_feature.settings.image_position.option_left"
        },
        {
          "value": "right",
          "label": "t:sections.shoppable_feature.settings.image_position.option_right"
        }
      ]
    },
    {
      "id": "image_size",
      "type": "range",
      "label": "t:sections.shoppable_feature.settings.image_size.label",
      "unit": "%",
      "min": 50,
      "max": 65,
      "step": 1,
      "default": 55
    },
    {
      "id": "aspect_ratio",
      "type": "select",
      "label": "t:shared.settings.aspect_ratio.label",
      "options": [
        {
          "label": "t:shared.settings.aspect_ratio.option_square",
          "value": "square"
        },
        {
          "label": "t:shared.settings.aspect_ratio.option_landscape_alt",
          "value": "landscape_alt"
        },
        {
          "label": "t:shared.settings.aspect_ratio.option_portrait_alt",
          "value": "portrait_alt"
        },
        {
          "label": "t:shared.settings.aspect_ratio.option_natural",
          "value": "natural"
        }
      ],
      "default": "portrait_alt"
    },
    {
      "type": "header",
      "content": "t:sections.shoppable_feature.settings.text__header.content"
    },
    {
      "id": "heading",
      "type": "text",
      "label": "t:sections.shoppable_feature.settings.heading.label",
      "default": "Shoppable image - editorial"
    },
    {
      "id": "heading_tag",
      "type": "select",
      "label": "t:shared.section_blocks.heading.settings.heading_tag.label",
      "default": "h2",
      "options": [
        {
          "value": "h2",
          "label": "t:shared.section_blocks.heading.settings.heading_tag.options.h2"
        },
        {
          "value": "h3",
          "label": "t:shared.section_blocks.heading.settings.heading_tag.options.h3"
        },
        {
          "value": "h4",
          "label": "t:shared.section_blocks.heading.settings.heading_tag.options.h4"
        },
        {
          "value": "h5",
          "label": "t:shared.section_blocks.heading.settings.heading_tag.options.h5"
        },
        {
          "value": "h6",
          "label": "t:shared.section_blocks.heading.settings.heading_tag.options.h6"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": "t:shared.section_blocks.heading.settings.heading_tag.info"
    },
    {
      "type": "select",
      "id": "heading_color",
      "label": "t:shared.settings.heading_color.label",
      "default": "c-heading-text-dark",
      "options": [
        {
          "value": "c-heading-text-dark",
          "label": "t:shared.settings.heading_color.option_dark"
        },
        {
          "value": "c-heading-text-light",
          "label": "t:shared.settings.heading_color.option_light"
        }
      ]
    },
    {
      "type": "range",
      "id": "heading_max_width",
      "min": 0,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "label": "t:sections.shoppable_feature.settings.heading_max_width.label",
      "default": 1000
    },
    {
      "id": "subheading",
      "type": "richtext",
      "label": "t:sections.shoppable_feature.settings.subheading.label",
      "default": "<p>Use this section to highlight different products within an image with an integrated carousel</p>"
    },
    {
      "type": "select",
      "id": "subheading_color",
      "label": "t:shared.settings.subheading_color.label",
      "default": "c-subheading-text-dark",
      "options": [
        {
          "value": "c-subheading-text-dark",
          "label": "t:shared.settings.subheading_color.option_dark"
        },
        {
          "value": "c-subheading-text-light",
          "label": "t:shared.settings.subheading_color.option_light"
        }
      ]
    },
    {
      "type": "range",
      "id": "subheading_max_width",
      "min": 0,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "label": "t:sections.shoppable_feature.settings.subheading_max_width.label",
      "default": 1000
    },
    {
      "type": "header",
      "content": "t:sections.shoppable_feature.settings.cta_header.content"
    },
    {
      "id": "link",
      "type": "url",
      "label": "t:sections.shoppable_feature.settings.link.label"
    },
    {
      "id": "link_text",
      "type": "text",
      "label": "t:sections.shoppable_feature.settings.link_text.label",
      "default": "Shop now"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "t:shared.settings.button_style.label",
      "default": "btn--callout",
      "options": [
        {
          "value": "btn--solid",
          "label": "t:shared.settings.button_style.option_solid"
        },
        {
          "value": "btn--outline",
          "label": "t:shared.settings.button_style.option_outline"
        },
        {
          "value": "btn--callout",
          "label": "t:shared.settings.button_style.option_text"
        }
      ]
    },
    {
      "type": "select",
      "id": "button_color",
      "label": "t:shared.settings.button_color.label",
      "options": [
        {
          "value": "btn--dark",
          "label": "t:shared.settings.button_color.dark"
        },
        {
          "value": "btn--light",
          "label": "t:shared.settings.button_color.light"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:shared.settings.section_style.header_style.content"
    },
    {
      "id": "enable_animation",
      "type": "checkbox",
      "label": "t:shared.settings.section_style.enable_animation.label",
      "info": "t:shared.settings.section_style.enable_animation.info",
      "default": true
    },
    {
      "type": "select",
      "id": "divider_style",
      "label": "t:shared.settings.section_style.divider_style.label",
      "default": "none",
      "options": [
        {
          "label": "t:shared.settings.section_style.divider_style.option_none",
          "value": "none"
        },
        {
          "label": "t:shared.settings.section_style.divider_style.option_solid",
          "value": "solid"
        }
      ]
    },
    {
      "type": "select",
      "id": "section_padding",
      "label": "t:sections.shoppable_feature.settings.section_padding.label",
      "default": "section--vertical-padding-top-bottom",
      "options": [
        {
          "label": "t:shared.settings.section_style.section_padding.option_none",
          "value": "section--vertical-padding-none"
        },
        {
          "label": "t:shared.settings.section_style.section_padding.option_both",
          "value": "section--vertical-padding-top-bottom"
        },
        {
          "label": "t:shared.settings.section_style.section_padding.option_top",
          "value": "section--vertical-padding-top-only"
        },
        {
          "label": "t:shared.settings.section_style.section_padding.option_bottom",
          "value": "section--vertical-padding-bottom-only"
        }
      ]
    },
    {
      "type": "select",
      "id": "content_position_desktop",
      "label": "t:sections.shoppable_feature.settings.content_position_desktop.label",
      "default": "inside",
      "options": [
        {
          "label": "t:sections.shoppable_feature.settings.content_position_desktop.option_inside",
          "value": "inside"
        },
        {
          "label": "t:sections.shoppable_feature.settings.content_position_desktop.option_outside",
          "value": "outside"
        }
      ]
    },
    {
      "type": "select",
      "id": "content_position_mobile",
      "label": "t:sections.shoppable_feature.settings.content_position_mobile.label",
      "default": "above",
      "options": [
        {
          "label": "t:sections.shoppable_feature.settings.content_position_mobile.option_above",
          "value": "above"
        },
        {
          "label": "t:sections.shoppable_feature.settings.content_position_mobile.option_below",
          "value": "below"
        }
      ]
    },
    {
      "type": "range",
      "id": "content_padding_y",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "t:sections.shoppable_feature.settings.content_padding.label",
      "info": "t:sections.shoppable_feature.settings.content_padding.desktop_vertical_info",
      "default": 0
    },
    {
      "type": "range",
      "id": "content_padding_x",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "t:sections.shoppable_feature.settings.content_padding.label",
      "info": "t:sections.shoppable_feature.settings.content_padding.desktop_horizontal_info",
      "default": 40
    },
    {
      "type": "range",
      "id": "content_padding_y_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.shoppable_feature.settings.content_padding.mobile_label",
      "info": "t:sections.shoppable_feature.settings.content_padding.mobile_vertical_info",
      "default": 0
    },
    {
      "type": "range",
      "id": "content_padding_x_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.shoppable_feature.settings.content_padding.mobile_label",
      "info": "t:sections.shoppable_feature.settings.content_padding.mobile_horizontal_info",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "hide_hotspots",
      "label": "t:sections.shoppable_feature.settings.hide_hotspots.label",
      "info": "t:sections.shoppable_feature.settings.hide_hotspots.info",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_full_width",
      "label": "t:sections.shoppable_feature.settings.enable_full_width.label",
      "default": false
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:shared.settings.text_color.label",
      "default": "#111111"
    },
    {
      "type": "select",
      "id": "link_color_scheme",
      "label": "t:shared.settings.link_color_scheme.label",
      "options": [
        {
          "value": "light",
          "label": "t:shared.settings.link_color_scheme.option_light"
        },
        {
          "value": "dark",
          "label": "t:shared.settings.link_color_scheme.option_dark"
        }
      ],
      "default": "dark"
    }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "t:sections.shoppable_feature.blocks.hotspot.name",
      "limit": 6,
      "settings": [
        {
          "id": "product_item",
          "type": "product",
          "label": "t:sections.shoppable_feature.blocks.hotspot.settings.product_item.label"
        },
        {
          "id": "horizontal_position",
          "type": "range",
          "label": "t:sections.shoppable_feature.blocks.hotspot.settings.horizontal_position.label",
          "unit": "%",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        },
        {
          "id": "vertical_position",
          "type": "range",
          "label": "t:sections.shoppable_feature.blocks.hotspot.settings.vertical_position.label",
          "unit": "%",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.shoppable_feature.presets.name",
      "blocks": [
        {
          "type": "hotspot",
          "settings": {
            "horizontal_position": 35,
            "vertical_position": 65
          }
        },
        {
          "type": "hotspot",
          "settings": {
            "horizontal_position": 80,
            "vertical_position": 60
          }
        },
        {
          "type": "hotspot",
          "settings": {
            "horizontal_position": 60,
            "vertical_position": 45
          }
        }
      ]
    }
  ]
}
{% endschema %}
