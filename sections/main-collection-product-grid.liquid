{%- liquid
  assign paginated = false
  if section.settings.pagination == 'paginated'
    assign paginated = true
  endif

  assign per_page = section.settings.rows | times: section.settings.columns_desktop
  assign filter_bar_enabled = false
  if section.settings.show_item_count or section.settings.show_sort or section.settings.show_filters
    assign filter_bar_enabled = true
  endif

  assign effective_collapse_filter_bar = section.settings.collapse_filter_bar
  if collection.handle contains 'zone'
    assign effective_collapse_filter_bar = false
  else
    assign effective_collapse_filter_bar = true
  endif

  assign swatch_options = settings.swatch_options | downcase | split: ', '
  assign chip_options = settings.chip_options | downcase | split: ', '

  assign is_ajax = false
  assign is_filters = true

  for filter in collection.filters
    for value in filter.active_values
      if value != blank
        assign is_filters = false
        break
      endif
    endfor
  endfor

  assign promo_block = null

  for block in section.blocks
    if block.type == 'item'
      assign promo_block = block
      break
    endif
  endfor

  assign promo_has_content = false

  if promo_block.settings.video != blank or promo_block.settings.video_url != blank or promo_block.settings.video_embed != blank or promo_block.settings.image != blank
    assign promo_has_content = true
  endif

  if promo_has_content and is_filters == true
    assign is_ajax = true
  endif

  assign product_columns_desktop = section.settings.columns_desktop

  case product_columns_desktop
  when '5'
    assign promo_sizes = '(max-width: 720px) 90vw, (max-width: 1400px) calc((93.4vw - (12px * 3)) / 5), 500px'
  when '3'
    assign promo_sizes = '(max-width: 720px) 90vw, (max-width: 1400px) calc((93.4vw - (12px * 3)) / 3), 900px'
  when '2'
    assign promo_sizes = '(max-width: 720px) 90vw, (max-width: 1400px) calc((93.4vw - (12px * 3)) / 2), 1400px'
  else
    # Using a 4 item grid as default for sizes
    assign promo_sizes = '(max-width: 720px) 90vw, (max-width: 1400px) 600px'
  endcase

  assign card_position = promo_block.settings.placement_after_card

  assign prioritize_product_grid = false
  if section.index == 1
    assign prioritize_product_grid = true
  endif

  assign promo_prioritize_loading = false
  assign promo_fetch_priority = ''
  if prioritize_product_grid and card_position < 3
    assign promo_prioritize_loading = true
    assign promo_fetch_priority = 'high'
  endif
-%}

<section
  data-section-id="{{ section.id }}"
  data-section-type="collection"
  data-layout-type="grid"
  data-pagination-type="{{ section.settings.pagination }}"
  data-collection-item-count="{{ collection.all_products_count }}"
  data-collection-items-per-page="{{ per_page }}"
  data-collection-columns-desktop="{{ section.settings.columns_desktop }}"
  data-collection-columns-mobile="{{ section.settings.columns_mobile }}"
  data-enable-sticky-filter-sidebar="{{ section.settings.enable_sticky_filter_sidebar }}"

  class="
    section
    section--includes-product-items
    section--full-width
    section--medium-gaps
    collection
    collection--pagination-{{ section.settings.pagination }}
    {% if filter_bar_enabled %}collection--has-filter-bar{% endif %}
    {% if settings.enable_section_animations and section.settings.enable_animation %}
      animation
      animation--collection
    {% endif %}
  "

  style="
    --collection-columns-desktop: {{ section.settings.columns_desktop }};
    --collection-columns-mobile: {{ section.settings.columns_mobile }};
  "
>
  {%- if section.settings.divider_style == 'solid' -%}
    <div class="collection__divider"></div>
  {%- endif -%}
  <div class="collection__inner">
    {%- if collection.all_products_count > 0 -%}
      <script type="application/json" data-tags>
        {% if collection.all_tags.size > 0 %}
          [
            {%- for tag in collection.all_tags -%}
              { "label": "{{ tag | escape }}", "handle": "{{ tag | handleize }}" }
              {%- if forloop.last == false -%}, {%- endif -%}
            {%- endfor -%}
          ]
        {% else %}
          []
        {% endif %}
      </script>

      {% paginate collection.products by per_page, window_size: 5 %}
        <div class="collection__container">
          <div class="collection__content">
            {% render 'filter-bar',
              results: collection,
              show_item_count: section.settings.show_item_count,
              show_sort: section.settings.show_sort,
              show_filters: section.settings.show_filters,
              filter_location: section.settings.desktop_filter_location,
              show_swatch_filters: section.settings.show_swatch_filters,
              swatch_options: swatch_options,
              show_chip_filters: section.settings.show_chip_filters,
              chip_options: chip_options,
              enable_sticky_filter_bar: section.settings.enable_sticky_filter_bar,
              collapse_filter_bar: section.settings.collapse_filter_bar,
              chip_layout: section.settings.chip_layout,
              hide_single_value_filters: true
            %}

            {% render 'mobile-filters',
              results: collection,
              show_sort: section.settings.show_sort,
              show_filters: section.settings.show_filters,
              enable_sticky_filter_bar: section.settings.enable_sticky_filter_bar,
              hide_single_value_filters: true
            %}

            <div class="collection__main-area">
              {%- if section.settings.desktop_filter_location == 'sidebar' -%}
                {% render 'filter-sidebar',
                  results: collection,
                  show_filters: section.settings.show_filters,
                  collapse_filter_bar: section.settings.collapse_filter_bar,
                  collapse_filter_groups: effective_collapse_filter_bar,
                  show_swatch_filters: section.settings.show_swatch_filters,
                  swatch_options: swatch_options,
                  show_chip_filters: section.settings.show_chip_filters,
                  chip_options: chip_options,
                  chip_layout: section.settings.chip_layout,
                  hide_single_value_filters: true
                %}
              {%- endif -%}

              <div class="collection__window">
                <div class="collection__loading" data-loading>
                  {%- render 'loader' -%}
                </div>

                <div
                  id="root"
                  class="animation--collection-items"
                  data-partial
                  data-collection-products-count="{{ collection.products_count }}"
                >
                  <div
                    class="
                      collection__products
                      collection__infinite-container
                      {% if collection.products_count == 0 %}
                        collection__products--no-products
                      {% endif %}
                    "
                    {% if is_ajax %}data-plp-ajax{% endif %}
                  >
                    {% for product in collection.products %}
                      {% assign prioritize_loading = false %}
                      {% assign fetch_priority = '' %}
                      {% if prioritize_product_grid and forloop.index <= 3 %}
                        {% assign prioritize_loading = true %}
                        {% assign fetch_priority = 'high' %}
                      {% endif %}
                      {% if is_ajax %}<div data-plp-item class="image image--animate animation--lazy-load">{% endif %}
                      {% render 'product-item',
                        prod: product,
                        product_columns_desktop: section.settings.columns_desktop,
                        product_columns_mobile: section.settings.columns_mobile,
                        aspect_ratio: settings.product_listing_aspect_ratio,
                        has_grid_reveal: true,
                        title_tag: 'h2',
                        prioritize_loading: prioritize_loading,
                        fetch_priority: fetch_priority
                      %}
                      {% if is_ajax %}</div>{% endif %}
                      {%- if promo_has_content and paginate.current_page == 1 and is_filters -%}
                        {%- if forloop.index == card_position and collection.products.size >= card_position -%}
                          {% if is_ajax %}<div data-plp-item class="image image--animate animation--lazy-load">{% endif %}
                            {%- render 'collection-promo-card',
                              promo_block: promo_block,
                              promo_sizes: promo_sizes,
                              prioritize_loading: promo_prioritize_loading,
                              fetch_priority: promo_fetch_priority
                            -%}
                          {% if is_ajax %}</div>{% endif %}
                        {%- elsif collection.products.size < card_position and forloop.last -%}
                          {% if is_ajax %}<div data-plp-item class="image image--animate animation--lazy-load">{% endif %}
                            {%- render 'collection-promo-card',
                              promo_block: promo_block,
                              promo_sizes: promo_sizes,
                              prioritize_loading: promo_prioritize_loading,
                              fetch_priority: promo_fetch_priority
                            -%}
                          {% if is_ajax %}</div>{% endif %}
                        {%- endif -%}
                      {%- endif -%}
                    {% else %}
                      <div class="collection__empty{% if is_ajax %} hidden{% endif %}">
                        <div>{{ 'collections.general.no_products' | t }}</div>
                        <button type="button" class="btn btn--text-link" data-clear-all-filters>
                          {{ 'filters.clear_filters' | t }}
                        </button>
                      </div>
                    {% endfor %}
                  </div>

                  {% unless paginated %}
                    <div>
                      {% render 'pagination',
                        paginate: paginate,
                        type: 'general.pagination.products',
                        display_paginate_item_count_only: true
                      %}
                      <div class="collection__infinite-trigger">
                        {% if paginate.next %}
                          <a href="{{ paginate.next.url }}" class="btn btn--outline btn--light no-transition" data-click-to-load>
                            {{- 'general.pagination.load_more' | t -}}
                          </a>
                        {% endif %}
                      </div>
                    </div>
                  {% endunless %}

                  {% if paginated %}
                    <div {% if is_ajax %}data-plp-paginate{% endif %}>
                      {% if paginate.pages > 1 %}
                        {% render 'pagination',
                          paginate: paginate,
                          type: 'general.pagination.products',
                          show_item_count: false
                        %}
                      {% else %}
                        {% render 'pagination',
                          paginate: paginate,
                          type: 'general.pagination.products',
                          display_paginate_item_count_only: true
                        %}
                      {% endif %}
                    </div>
                  {% endif %}
                </div>
              </div>
            </div>
          </div>
        </div>
      {% endpaginate %}

      {% render 'filter-drawer',
        results: collection,
        show_sort: section.settings.show_sort,
        show_filters: section.settings.show_filters,
        show_swatch_filters: section.settings.show_swatch_filters,
        swatch_options: swatch_options,
        show_chip_filters: section.settings.show_chip_filters,
        chip_options: chip_options,
        chip_layout: section.settings.chip_layout,
        collapse_filter_groups: effective_collapse_filter_bar,
        hide_single_value_filters: true
      %}
    {%- else -%}
      <div class="collection__empty ta-c">
        <p class="fs-body-100">{{ 'collections.general.no_matches' | t }}</p>
        <a class="btn btn--text-link" href="{{ routes.all_products_collection_url }}">{{ 'general.404.link' | t }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

