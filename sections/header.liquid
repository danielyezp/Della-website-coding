{%- liquid
  assign enable_transparent_template_list = section.settings.enable_transparent_template_list | downcase | split: ', '
  assign transparent_header_enabled = false
  if section.settings.enable_transparent_on_home and template.name == 'index'
    assign transparent_header_enabled = true
  endif

  for template_item in enable_transparent_template_list
    if template_item contains '.'
      assign template_name = template_item | split: '.' | first
      assign suffix_name = template_item | split: '.' | last

      if template_name == template.name and suffix_name == template.suffix
        assign transparent_header_enabled = true
      endif
    else
      if template_item == template.name
        assign transparent_header_enabled = true
      endif
    endif

    if transparent_header_enabled
      break
    endif
  endfor
-%}

<script>

  {% if section.settings.enable_sticky_header %}
    document.documentElement.classList.add("sticky-header-enabled");
  {% endif %}
  {% if transparent_header_enabled %}
    document.body.classList.add("header-transparent");
  {% endif %}
  {% if section.settings.layout == 'logo-center_nav-below' %}
    document.body.classList.add("quick-search-position-left");
  {% else %}
    document.body.classList.add("quick-search-position-right");
  {% endif %}
</script>
{%- liquid
  assign logo = section.settings.logo
  assign logo_width = section.settings.logo_width
  assign mobile_logo_width = section.settings.mobile_logo_width

  assign layout = section.settings.layout

  assign logo_position = 'center'

  if layout contains 'logo-left'
    assign logo_position = 'left'
  endif

  assign navigation_position = 'below'

  if layout contains 'nav-left'
    assign navigation_position = 'left'
  elsif layout contains 'nav-center'
    assign navigation_position = 'center'
  endif

  assign color_count_transparent = section.settings.color_count_transparent
  assign logo_transparent = section.settings.logo_transparent

  assign menu = section.settings.menu
  assign secondary_menu = section.settings.secondary_menu
  assign sub_menu = section.settings.sub_menu
  assign mobile_menu = section.settings.menu_mobile

  assign links = linklists[menu].links
  assign secondary_links = linklists[secondary_menu].links
  assign sub_links = linklists[sub_menu].links
  assign mobile_links = linklists[mobile_menu].links | default: linklists[menu].links

  assign secondary_menu_valid = false

  if secondary_menu != blank and secondary_menu != menu
    assign secondary_menu_valid = true
  endif

  assign enable_locale_selector = section.settings.enable_locale_selector
  assign enable_country_selector = section.settings.enable_country_selector
  assign show_social_media = section.settings.show_social_media
  assign show_social_media_mobile = section.settings.show_social_media_mobile
  assign account_placement = section.settings.account_placement
  assign account_custom_icon = section.settings.account_icon

  assign enable_location = section.settings.enable_location
  assign location_icon = section.settings.location_icon
  assign location_icon_mobile = section.settings.location_icon_mobile
  assign location_url = section.settings.location_url
  assign location_text = section.settings.location_text
  assign location_button_style = section.settings.location_button_style

  assign locale_selector = false
  assign country_selector = false

  if enable_locale_selector and shop.published_locales.size > 1
    assign locale_selector = true
  endif

  if enable_country_selector and localization.available_countries.size > 1
    assign country_selector = true
  endif

  assign support_menu_handle =  section.settings.support_menu
  assign support_menu = linklists[support_menu_handle].links

  assign support_menu_valid = false

  if support_menu != blank and support_menu != menu
    assign support_menu_valid = true
  endif

  assign announcement_bar_linklist_handle =  section.settings.announcement_bar_linklist
  assign announcement_bar_linklist = linklists[announcement_bar_linklist_handle].links
  assign announcement_bar_icon =  section.settings.announcement_bar_icon
  assign announcement_bar_sub_content =  section.settings.announcement_bar_sub_content
-%}

{%- capture logo_sizes -%}(max-width: 1199px) {{ mobile_logo_width }}px, {{ logo_width }}px{%- endcapture -%}
{%- capture logo_widths -%}
  {{ mobile_logo_width }}, {{ mobile_logo_width | times: 1.75 | round }}, {{ mobile_logo_width | times: 2 }}, {{ logo_width }}, {{ logo_width | times: 1.75 | round }}, {{ logo_width | times: 2 }}
{%- endcapture -%}

{%- comment -%} theme-check-disable UnusedAssign {%- endcomment -%}
{%- assign capitalize_logo = settings.capitalize_logo -%}
{%- assign logo_text_transform = 'none' -%}
{%- if capitalize_logo -%}
  {%- assign logo_text_transform = 'uppercase' -%}
{%- endif -%}
{%- comment -%} theme-check-enable UnusedAssign {%- endcomment -%}

{%- assign mobile_menu_image_blocks = section.blocks | where: 'type', 'mobile_menu_images' -%}

{%- capture header_logo -%}
  <span class="header__logo">
    <a
      class="header__logo-link"
      href="{{ routes.root_url }}"
      {% if logo != blank or logo_transparent != blank %}
        aria-label="{{ shop.name }}"
      {% endif %}
    >
      {%- if logo != blank -%}
        {{ logo | image_url: width: logo_width | image_tag: width: logo.width, height: logo.height, sizes: logo_sizes, widths: logo_widths, loading: 'eager', fetchpriority: 'auto', decoding: 'async', class: 'image regular-logo' }}
      {%- endif -%}

      {%- if logo_transparent != blank -%}
        {{ logo_transparent | image_url: width: logo_width | image_tag: width: logo_transparent.width, height: logo_transparent.height, sizes: logo_sizes, widths: logo_widths, loading: 'eager', fetchpriority: 'auto', decoding: 'async', class: 'image transparent-logo' }}
      {%- endif -%}

      {%- if logo == blank or logo_transparent == blank -%}
        <span class="header__logo-text{% if logo != blank or logo_transparent != blank %} visually-hidden{% endif %}">{{ shop.name }}</span>
      {%- endif -%}
    </a>
  </span>
{%- endcapture -%}

{%- capture search_icon -%}
  <a
    class="
      header__icon-touch
      header__icon-touch--search
      {% if settings.enable_quick_search %}no-transition{% endif %}
    "
    href="{{ routes.search_url }}"
    {% if settings.enable_quick_search %}
      data-search
    {% endif %}
    aria-label="{{ 'general.accessibility.open_search' | t }}"
    aria-controls="MainQuickSearch"
    aria-expanded="false"
  >
    {% render 'icon-button', icon: 'header-search', view_box_custom: '0 0 20 20' %}
    {% render 'icon-button', icon: 'header-menu-close' %}
  </a>
{%- endcapture -%}

{%- capture account_icon -%}
  <a
    class="header__icon-touch header__icon-touch--account"
    href="{{ routes.account_url }}"
    aria-label="{{ 'general.accessibility.go_account' | t }}"
  >
    {% render 'icon-button', icon: 'header-account' %}
  </a>
{%- endcapture -%}

{%- capture cart_icon -%}
  <a
    class="header__icon-touch no-transition"
    href="{{ routes.cart_url }}"
    aria-label="{{ 'general.accessibility.open_cart' | t }}"
    data-js-cart-icon="{{ section.settings.cart_icon }}"
  >
    {% assign cart_icon_name = 'header-shopping-[[ci]]' | replace: '[[ci]]', section.settings.cart_icon %}
    {% render 'icon-button', icon: cart_icon_name %}

    <span data-js-cart-count{% if cart.item_count == 0 %} class="hidden"{% endif %}>{{ cart.item_count }}</span>
  </a>
{%- endcapture -%}

{%- capture primary_nav -%}
  <div
    class="header__links-primary-scroll-container"
    data-scroll-container
    data-at-start="true"
    data-at-end="true"
    data-axis="horizontal"
  >
    <button
      class="scroll-button"
      data-position="start"
      data-direction="backwards"
      title="{{ 'general.accessibility.previous' | t }}"
    >
      {% render 'icon' with icon: 'chevron' %}
    </button>
    <div class="scroll-overflow-indicator-wrap" data-position="start">
      <div class="scroll-overflow-indicator"></div>
    </div>
    <div data-scroll-container-viewport>
      <div class="scroll-sentinal scroll-sentinal--start" data-position="start"></div>
      <nav class="header__links header__links-primary" data-navigation aria-label="Primary navigation">
        {%- if menu == blank and secondary_menu != blank -%}
          {% render 'navigation' with menu: secondary_links, blocks: section.blocks %}
        {%- else -%}
          {% render 'navigation' with menu: links, blocks: section.blocks %}
        {%- endif -%}
      </nav>
      <div class="scroll-sentinal scroll-sentinal--end" data-position="end"></div>
    </div>
    <div class="scroll-overflow-indicator-wrap" data-position="end">
      <div class="scroll-overflow-indicator"></div>
    </div>
    <button
      class="scroll-button"
      data-position="end"
      data-direction="forwards"
      title="{{ 'general.accessibility.next' | t }}"
    >
      {% render 'icon' with icon: 'chevron' %}
    </button>
  </div>
{%- endcapture -%}

{%- capture secondary_nav -%}
  {%- if secondary_menu_valid -%}
    <nav class="header__links header__links-secondary" data-secondary-navigation aria-label="Secondary navigation">
      {% render 'navigation' with menu: secondary_links, no_children: true %}
    </nav>
  {%- endif -%}
{%- endcapture -%}

{%- capture menu_icon -%}
  <button
    class="header__menu-icon header__icon-touch header__icon-menu"
    aria-label="{{ 'general.accessibility.open_menu' | t }}"
    aria-expanded="false"
    data-aria-label-closed="{{ 'general.accessibility.open_menu' | t }}"
    data-aria-label-opened="{{ 'general.accessibility.close_menu' | t }}"
    data-js-menu-button
  >
    {% render 'icon-button', icon: 'header-menu', view_box_custom: '0 0 25 16' %}
    {% render 'icon-button', icon: 'header-menu-close' %}
  </button>
{%- endcapture -%}

{%- capture filler -%}<div class="header__filler"></div>{%- endcapture -%}

{%- capture localization_dropdowns -%}
  {%- if locale_selector or country_selector -%}
    <nav class="header__cross-border fs-body-50" data-secondary-navigation aria-label="Localization navigation">
      {%
        render 'cross-border' with
        show_locale: locale_selector,
        show_country: country_selector,
        id: 'header',
        desktop_only: true
      %}
    </nav>
  {%- endif -%}
{%- endcapture -%}

{%- capture social_icons -%}
  {%- if show_social_media -%}
    {% render 'social-icons' %}
  {%- endif -%}
{%- endcapture -%}

{%- capture social_icons_mobile -%}
  {%- if show_social_media_mobile -%}
    {% render 'social-icons' %}
  {%- endif -%}
{%- endcapture -%}

{%- capture social_icons_and_second_menu -%}
  {{ social_icons }}
  {{ secondary_nav }}
{%- endcapture -%}

{%- capture sub_nav -%}
  <div
    class="header__links-sub-scroll-container"
    data-scroll-container
    data-at-start="true"
    data-at-end="false"
    data-axis="horizontal"
  >
    <button
      class="scroll-button"
      data-position="start"
      data-direction="backwards"
      title="{{ 'general.accessibility.previous' | t }}"
    >
      {% render 'icon' with icon: 'chevron' %}
    </button>
    <div class="scroll-overflow-indicator-wrap" data-position="start">
      <div class="scroll-overflow-indicator"></div>
    </div>
    <div data-scroll-container-viewport>
      <div class="scroll-sentinal scroll-sentinal--start" data-position="start"></div>
      <nav class="header__links header__links-primary" data-navigation aria-label="Sub navigation">
        {%- render 'navigation', menu: sub_links, limit: 4, blocks: section.blocks -%}
      </nav>
      <div class="scroll-sentinal scroll-sentinal--end" data-position="end"></div>
    </div>
    <div class="scroll-overflow-indicator-wrap" data-position="end">
      <div class="scroll-overflow-indicator"></div>
    </div>
    <button
      class="scroll-button"
      data-position="end"
      data-direction="forwards"
      title="{{ 'general.accessibility.next' | t }}"
    >
      {% render 'icon' with icon: 'chevron' %}
    </button>
  </div>
{%- endcapture -%}

{%- capture location_button -%}
  {%- if enable_location and location_url != blank and location_text != blank or location_icon != blank -%}
    <a
      class="header__location-button btn btn--light {{ location_button_style }}"
      href="{{ location_url }}"
      aria-label="{{ location_text }}"
    >
      {%- if location_icon != blank -%}
        {%- render 'image', image: location_icon, wrapper_class: 'button-icon', sizes: logo_sizes, prioritize_loading: true, fetch_priority: 'low' -%}
      {%- endif -%}
      {%- if location_text != blank -%}
        <span class="button-text ff-body fs-body-50">{{ location_text }}</span>
      {%- endif -%}
    </a>
  {%- endif -%}
{%- endcapture -%}

{%- capture location_button_mobile -%}
  {%- if enable_location and location_url != blank and location_text != blank or location_icon_mobile != blank -%}
    <a
      class="header__location-button header__location-button--mobile btn btn--dark {{ location_button_style }}"
      href="{{ location_url }}"
      aria-label="{{ location_text }}"
    >
      {%- if location_icon_mobile != blank -%}
        {%- render 'image', image: location_icon_mobile, wrapper_class: 'button-icon', sizes: logo_sizes, prioritize_loading: true, fetch_priority: 'low' -%}
      {%- endif -%}
      {%- if location_text != blank -%}
        <span>{{ location_text }}</span>
      {%- endif -%}
    </a>
  {%- endif -%}
{%- endcapture -%}


<header
  data-section-id="{{ section.id }}"
  data-section-type="header"
  {% if section.settings.enable_sticky_header %}
    data-enable-sticky-header="true"
  {% endif %}
  {% if transparent_header_enabled %}
    data-transparent-header="true"
  {% endif %}
  class="
    header
    header--layout-{{ layout | replace: "_", "-" }}
    {% if logo != blank -%}
      header--has-logo
    {%- endif %}
    {% if transparent_header_enabled %}
      header--transparent
    {% endif %}
    {% if logo_transparent != blank %}
      header--has-transparent-logo
    {% endif %}
    {% if shop.customer_accounts_enabled -%}
      header--has-accounts
    {%- endif %}
    {% if secondary_menu_valid -%}
      header--has-secondary-menu
    {%- endif %}
    {% if menu == blank and secondary_menu != blank -%}
      header--primary-menu-is-secondary
    {%- endif %}
    {% if settings.capitalize_navigation -%}
      header--navigation-is-all-caps
    {%- endif %}
    {% if social_icons != blank -%}
      header--has-social-links
    {%- endif %}
    {% if enable_locale_selector or enable_country_selector -%}
      header--has-country-or-locale
    {%- endif %}
    {% if support_menu_valid -%}
      header--has-support-menu
    {%- endif %}
  "
  {% if section.settings.enable_sticky_header %}
    data-is-sticky="true"
  {% endif %}
  data-navigation-position="{{ navigation_position }}"
  data-logo-position="{{ logo_position }}"
  style="
    --logo-width: {{ logo_width }}px;
    --mobile-logo-width: {{ mobile_logo_width }}px;
    --color-cart-count-transparent: {{ color_count_transparent }};
    --divider-width: {{ section.settings.divider_width }};
  "
>
  {%- if location_button != blank or localization_dropdowns != blank -%}
    <div class="header__topbar-tools">
      {{ location_button }}
      {{ localization_dropdowns }}
    </div>
  {%- endif -%}

  <div class="header__inner">
    <div class="header__row header__row-desktop upper  ">
      <div class="header__row-segment header__row-segment-desktop left">
        {%- if logo_position == 'center' -%}
          {{ secondary_nav }}
        {%- else -%}
          {%- if navigation_position == 'below' -%}
            {{ header_logo }}
          {%- else -%}
            {{ filler }}
          {%- endif -%}
        {%- endif -%}
      </div>

      <div class="header__row-segment header__row-segment-desktop header__row-segment-desktop--logo-left right">
        {{ social_icons }}
      </div>
    </div>

    {%- if logo_position == 'center' and navigation_position == 'below' -%}
      <div class="header__row header__row-desktop logo-only">
        {{ header_logo }}
      </div>
    {%- endif -%}

    {%- capture lower_left_content -%}
      {%- if logo_position == 'center' and navigation_position == 'below' -%}
        {{ search_icon }}
      {%- elsif logo_position == 'center' and navigation_position == 'left' -%}
        {{ primary_nav }}
      {%- elsif logo_position == 'left' and navigation_position == 'below' -%}
        {{ primary_nav }}
      {%- elsif logo_position == 'left' and navigation_position == 'left' -%}
        {{ header_logo }}
        {{ primary_nav }}
      {%- elsif logo_position == 'left' and navigation_position == 'center' -%}
        {{ header_logo }}
      {%- endif -%}
    {%- endcapture -%}

    <div class="header__row header__row-desktop lower {% if logo_position == 'center' %}three-segment{% endif %}">
      <div class="header__row-segment header__row-segment-desktop left js-header-segment-left {% if lower_left_content contains "header__links-list" %}contains-nav{% endif %}">
        {{ lower_left_content }}
      </div>

      {%- if logo_position == 'center' and navigation_position == 'below' -%}
        {{ primary_nav }}
      {%- elsif logo_position == 'center' and navigation_position == 'left' -%}
        {{ header_logo }}
      {%- elsif logo_position == 'left' and navigation_position == 'center' -%}
        {{ primary_nav }}
      {%- endif -%}

      <div class="header__row-segment header__row-segment-desktop right {% if sub_menu != blank %}contains-nav{% endif %}">
        {{ sub_nav }}
        {%- unless logo_position == 'center' and navigation_position == 'below' -%}
          {{ search_icon }}
        {%- endunless -%}
        {%- if shop.customer_accounts_enabled -%}
          {{ account_icon }}
        {%- endif -%}
        {{ cart_icon }}
      </div>
    </div>

    <div class="header__row header__row-mobile {% if logo_position == 'center' %}three-segment{% endif %}">
      {%- if logo_position == 'center' -%}
        <div class="header__row-segment left">
          {{ menu_icon }}
        </div>

        {{ header_logo }}

        <div class="header__row-segment right">
          {%- if shop.customer_accounts_enabled -%}
            {{ account_icon }}
          {%- endif -%}
          {{ cart_icon }}
        </div>
      {%- else -%}
        <div class="header__row-segment left">
          {{ menu_icon }}
          {{ search_icon }}
        </div>

        {{ header_logo }}

        <div class="header__row-segment right">
          {%- if shop.customer_accounts_enabled -%}
            {{ account_icon }}
          {%- endif -%}
          {{ cart_icon }}
        </div>
      {%- endif -%}
    </div>
    {% render 'support-menu', links: support_menu, blocks: section.blocks %}
  </div>

  <div class="no-js-menu no-js-menu--desktop">
    {% render 'no-js-navmenu' with menu: menu, secondary_menu: secondary_menu %}
  </div>

  {% render 'drawer-menu',
    links: mobile_links,
    sub_links: sub_links,
    secondary_links: secondary_links,
    locale_selector: locale_selector,
    country_selector: country_selector,
    mobile_menu_image_blocks: mobile_menu_image_blocks,
    social_icons_mobile: social_icons_mobile,
    location_button: location_button_mobile,
    show_social_media: show_social_media,
    bottom_links: announcement_bar_linklist,
    bottom_image: announcement_bar_icon,
    bottom_content: announcement_bar_sub_content,
    location_url: location_url,
    location_text: location_text,
    account_placement: account_placement,
    account_icon: account_custom_icon,
    featured_banner_image: section.settings.featured_banner_image,
    featured_banner_label: section.settings.featured_banner_label,
    featured_banner_link: section.settings.featured_banner_link,
    enable_expand_first: section.settings.enable_expand_first,
    blocks: section.blocks,
    localization_dropdowns: localization_dropdowns
  %}
</header>

<script>
  // Set heading height at component level
  const header = document.querySelector('[data-section-type="header"]');
  document.documentElement.style.setProperty('--height-header', header.offsetHeight + 'px');
</script>

{%- if settings.enable_confirmation_popup -%}
  <div
    class="
      purchase-confirmation-popup
      {% if settings.enable_section_animations %}
        animation
        animation--purchase-confirmation
      {% endif %}
    "
    data-purchase-confirmation-popup
  >
    <div class="purchase-confirmation-popup__inner"></div>
  </div>
{%- endif -%}

{% render 'flash-alert' %}

{% schema %}
{
  "name": "t:sections.header.name",
  "class": "header__outer-wrapper",
  "settings": [
    {
      "id": "layout",
      "type": "select",
      "label": "t:sections.header.settings.layout.label",
      "options": [
        {
          "value": "logo-center_nav-below",
          "label": "t:sections.header.settings.layout.option_logo-center_nav-below"
        },
        {
          "value": "logo-left_nav-left",
          "label": "t:sections.header.settings.layout.option_logo-left_nav-left"
        },
        {
          "value": "logo-left_nav-center",
          "label": "t:sections.header.settings.layout.option_logo-left_nav-center"
        },
        {
          "value": "logo-center_nav-left",
          "label": "t:sections.header.settings.layout.option_logo-center_nav-left"
        },
        {
          "value": "logo-left_nav-below",
          "label": "t:sections.header.settings.layout.option_logo-left_nav-below"
        }
      ]
    },
    {
      "id": "enable_sticky_header",
      "type": "checkbox",
      "label": "t:sections.header.settings.enable_sticky_header.label",
      "default": true
    },
    {
      "id": "enable_expand_first",
      "type": "checkbox",
      "label": "t:sections.header.settings.enable_expand_first.label",
      "info": "t:sections.header.settings.enable_expand_first.info",
      "default": false
    },
    {
      "type": "radio",
      "id": "cart_icon",
      "label": "t:sections.header.settings.cart_icon.label",
      "default": "bag",
      "options": [
        {
          "value": "bag",
          "label": "t:sections.header.settings.cart_icon.option_bag"
        },
        {
          "value": "cart",
          "label": "t:sections.header.settings.cart_icon.option_cart"
        }
      ]
    },
    {
      "id": "divider_width",
      "type": "select",
      "label": "t:sections.header.settings.divider_width.label",
      "default": "2px",
      "options": [
        {
          "value": "0px",
          "label": "t:sections.header.settings.divider_width.option_0px"
        },
        {
          "value": "1px",
          "label": "t:sections.header.settings.divider_width.option_1px"
        },
        {
          "value": "2px",
          "label": "t:sections.header.settings.divider_width.option_3px"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:shared.settings.disclosure.header__language.content",
      "info": "t:shared.settings.disclosure.header__language.info"
    },
    {
      "type": "checkbox",
      "id": "enable_locale_selector",
      "label": "t:shared.settings.disclosure.enable_locale_selector.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:shared.settings.disclosure.header__country.content",
      "info": "t:shared.settings.disclosure.header__country.info"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "label": "t:shared.settings.disclosure.enable_country_selector.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.social_media__header.content",
      "info": "t:sections.header.settings.social_media__header.info"
    },
    {
      "type": "checkbox",
      "id": "show_social_media",
      "label": "t:sections.header.settings.show_social_media.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_social_media_mobile",
      "label": "t:sections.header.settings.show_social_media_mobile.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.account_link.content"
    },
    {
