{%- liquid
  assign media_position_mobile = 'column'
  assign media_position_desktop = 'row'

  if section.settings.side_by_side == 'below'
    assign media_position_mobile = 'column-reverse'
  endif

  if section.settings.side_by_side_desktop == 'right'
    assign media_position_desktop = 'row-reverse'
  endif

  assign has_media_side = false
  if section.settings.title != blank or section.settings.subheading != blank or section.settings.button_link_text != blank or section.settings.video != blank or section.settings.video_url != blank
    assign has_media_side = true
  endif

  assign class_inner_media = ''
  if has_media_side
    assign class_inner_media = 'collapsible-row-list--has-media'
  endif
-%}

{%- assign filtered_block_count = 0 -%}
{%- for block in section.blocks -%}
  {%- if block.settings.title != blank or block.settings.text != blank or request.design_mode -%}
    {%- assign filtered_block_count = filtered_block_count | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}

{%- capture row_list_content -%}
  {%- for block in section.blocks -%}
    {% if block.settings.title != blank or block.settings.text != blank or request.design_mode %}
      {%- render 'collapsible-row-list-item',
        block: block,
        item_heading_font: section.settings.item_heading_font,
        forloop: forloop
      -%}
    {% endif %}
  {%- endfor -%}
{%- endcapture -%}

{%- if filtered_block_count > 0 -%}
  <div
    {% if section.settings.anchor_id != blank %}id="{{ section.settings.anchor_id | strip | handleize }}"{% endif %}
    class="
      collapsible-row-list
      section
      section--large-gaps
      {{ section.settings.section_padding }}
      section--divider-{{ section.settings.divider_style }}
      {% if settings.enable_section_animations and section.settings.enable_animation %}
        animation
        animation--collapsible-row-list
      {% endif %}
      link-color-scheme--{{ section.settings.link_color_scheme }}
    "
    data-section-id="{{ section.id }}"
    data-section-type="collapsible-row-list"
    style="
      --heading-alignment: {{ section.settings.heading_alignment }};
      {% if section.settings.content_width == 'custom' %}
        --content-width: {{ section.settings.custom_content_width }}px;
      {% endif %}
      --media-position-mobile: {{ media_position_mobile }};
      --media-position-desktop: {{ media_position_desktop }};
    "
  >
    <div class="collapsible-row-list__inner {{ class_inner_media }}">
      {%- if has_media_side -%}
        <div class="collapsible-row-list__content">
          <div class="collapsible-row-list__content-media">
            {%- if section.settings.title != blank -%}
              <{{ section.settings.heading_tag }} class="collapsible-row-list__heading ff-heading {{ section.settings.heading_font_class }} {{ section.settings.heading_color }}">
                {{ section.settings.title }}
              </{{ section.settings.heading_tag }}>
            {%- endif -%}

            {%- if section.settings.subheading != blank -%}
              <{{ section.settings.subheading_tag }} class="collapsible-row-list__subheading ff-subheading {{ section.settings.subheading_font_class }} {{ section.settings.subheading_color }} section-blocks__subheading">
                {{ section.settings.subheading }}
              </{{ section.settings.subheading_tag }}>
            {%- endif -%}

            {%- if section.settings.button_link_text != blank and section.settings.button_link != blank -%}
              {%-
                render 'button-block',
                wrapper_class: 'collapsible-row-list__button',
                link: section.settings.button_link,
                label: section.settings.button_link_text,
                button_style: section.settings.button_style,
                button_color: section.settings.button_color,
                button_alignment: section.settings.heading_alignment
              -%}
            {%- endif -%}

            {%- if section.settings.video != blank or section.settings.video_url != blank -%}
              {%- render 'video-module',
                id: section.id,
                class: 'collapsible-row-list__content-media-video',
                video: section.settings.video,
                video_url: section.settings.video_url,
                loop: true,
                video_source: section.settings.video_source,
                image: section.settings.image
              -%}
            {%- endif -%}
          </div>
          <div class="collapsible-row-list__content-list">
            {{ row_list_content }}
          </div>
        </div>
      {%- else -%}
        {{ row_list_content }}
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

