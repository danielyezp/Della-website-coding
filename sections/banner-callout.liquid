{%- render 'vite-tag' with '/frontend/styles/modules/banner-callout.css' -%}

{%- liquid
  assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0
  assign min_height = section.settings.min_height
  assign min_height_mobile = section.settings.min_height_mobile

  assign image_icon = section.settings.image_icon
  assign image_icon_mobile = section.settings.image_icon_mobile

  assign has_frame = section.settings.show_frame
  assign image_sizes = '(min-width: 1400px) 1400px, calc(100vw - calc(2 * 3.3vw))'
  if section.settings.full_width
    assign image_sizes = '100vw'
  endif
-%}

<div
  class="
    banner-callout
    {% if has_frame %}banner-callout--frame{% endif %}
    {% if section.settings.image != blank or section.settings.mobile_image != blank %}banner-callout--has-image{% endif %}
    section
    {% if section.settings.full_width %}section--full-width{% endif %}
    {{ section.settings.section_padding }}
    {% if settings.enable_section_animations and section.settings.enable_animation %}
      animation
      animation--banner-callout
    {% endif %}
  "
  style="
    --color-background: {{ section.settings.background_color }};
    --color-text: {{ section.settings.text_color }};
    --color-text-meta: {{ section.settings.text_color | color_modify: 'alpha', 0.6 }};
    --color-text-link: {{ section.settings.text_color }};
    --overlay-background: {{ section.settings.color_overlay }};
    {% if section.settings.color_overlay_gradient != blank %}
      --overlay-background-gradient: {{ section.settings.color_overlay_gradient }};
    {% endif %}
    --overlay-opacity: {{ overlay_opacity }};
    --min-height: {{ min_height }}px;
    --min-height-mobile: {{ min_height_mobile }}px;
    --icon-width: {{ section.settings.icon_width }}px;
    --icon-width-mobile: {{ section.settings.icon_width_mobile }}px;
    --width-heading: {{ section.settings.max_width_heading }}px;
    --corner-radius-desktop: {{ section.settings.corner_radius_desktop }}px;
    --corner-radius-mobile: {{ section.settings.corner_radius_mobile }}px;
    {% render 'overlay-button-vars', color_button_text: section.settings.button_text_color, color_button_background: section.settings.button_background_color %}
  "
  data-section-id="{{ section.id }}"
  data-section-type="banner-callout"
  data-client-visible
>
  <div class="banner-callout__inner">
    {%- if section.settings.image != blank -%}
      {%- render 'image',
        wrapper_class: "banner-callout__image",
        image: section.settings.image,
        mobile_image: section.settings.mobile_image,
        focal_point: section.settings.focal_point,
        mobile_focal_point: section.settings.mobile_focal_point,
        sizes: image_sizes
      -%}
    {%- endif -%}
    <div class="banner-callout__overlay"></div>
    <div class="banner-callout__content banner-callout__content--alignment-mobile-{{ section.settings.column_alignment_mobile }}">
      <div class="banner-callout__content-inner section-blocks animation--section-blocks">
        <div class="banner-callout__content-heading">
          {%- if section.settings.image_icon != blank -%}
            {%- render 'image',
              wrapper_class: 'banner-callout__icon-image',
              image: image_icon,
              mobile_image: image_icon_mobile,
              focal_point: section.settings.focal_point,
              sizes: image_sizes
            -%}
          {%- endif -%}

          {%- if section.settings.heading != blank -%}
            <{{ section.settings.heading_tag }} class="ff-heading {{ section.settings.heading_font_class }} {% if section.settings.text_color == 'rgba(0,0,0,0)' or section.settings.text_color == blank %}{{ section.settings.heading_color }}{% endif %} section-blocks__heading">
              {{ section.settings.heading }}
            </{{ section.settings.heading_tag }}>
          {%- endif -%}
        </div>

        <div class="banner-callout__text">
          {%- if section.settings.text != blank -%}
            <div class="section-blocks__text{% if section.settings.text_color == 'rgba(0,0,0,0)' or section.settings.text_color == blank %} {{ section.settings.custom_text_color }}{% endif %}">{{ section.settings.text }}</div>
          {%- endif -%}

          {%- if section.settings.link_text -%}
            {%-
              render 'button-block',
              wrapper_class: "banner-callout__button animation",
              link: section.settings.link,
              label: section.settings.link_text,
              is_overlay: true,
              is_small: true,
              button_style: section.settings.button_style
            -%}
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Banner Callout",
  "tag": "section",
  "class": "shopify-section--banner-callout shopify-section--full-width",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "range",
      "id": "min_height",
      "min": 200,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "t:shared.settings.banners.min_height.label",
      "default": 300
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "min": 300,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "t:shared.settings.banners.min_height_mobile.label",
      "default": 500
    },
    {
      "type": "image_picker",
      "id": "image_icon",
      "label": "Image icon"
    },
    {
      "type": "image_picker",
      "id": "image_icon_mobile",
      "label": "Mobile image icon"
    },
    {
      "type": "range",
      "id": "icon_width",
      "min": 40,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Image width",
      "default": 70
    },
    {
      "type": "range",
      "id": "icon_width_mobile",
      "min": 40,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Image width mobile",
      "default": 50
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Announce your sale"
    },
    {
      "id": "heading_tag",
      "type": "select",
      "label": "Heading tag",
      "default": "h4",
      "options": [
        {
          "value": "h2",
          "label": "t:shared.section_blocks.heading.settings.heading_tag.options.h2"
        },
        {
          "value": "h3",
          "label": "t:shared.section_blocks.heading.settings.heading_tag.options.h3"
        },
        {
          "value": "h4",
          "label": "t:shared.section_blocks.heading.settings.heading_tag.options.h4"
        },
        {
          "value": "h5",
          "label": "t:shared.section_blocks.heading.settings.heading_tag.options.h5"
        },
        {
          "value": "h6",
          "label": "t:shared.section_blocks.heading.settings.heading_tag.options.h6"
        }
      ]
    },
    {
      "type": "range",
      "id": "max_width_heading",
      "min": 100,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "t:shared.settings.banners.min_height_mobile.label",
      "default": 300
    },
    {
      "type": "paragraph",
      "content": "t:shared.section_blocks.heading.settings.heading_tag.info"
    },
    {
      "type": "select",
      "id": "heading_font_class",
      "label": "t:shared.settings.heading_font_class.label",
      "default": "fs-heading-3-base",
      "options": [
        {
          "value": "fs-heading-1-base",
          "label": "t:shared.settings.heading_font_class.option_heading_1"
        },
        {
          "value": "fs-heading-2-base",
          "label": "t:shared.settings.heading_font_class.option_heading_2"
        },
        {
          "value": "fs-heading-3-base",
          "label": "t:shared.settings.heading_font_class.option_heading_3"
        },
        {
          "value": "fs-heading-4-base",
          "label": "t:shared.settings.heading_font_class.option_heading_4"
        },
        {
          "value": "fs-heading-5-base",
          "label": "t:shared.settings.heading_font_class.option_heading_5"
        },
        {
          "value": "fs-heading-6-base",
          "label": "t:shared.settings.heading_font_class.option_heading_6"
        }
      ]
    },
    {
      "type": "select",
      "id": "heading_color",
      "label": "t:shared.settings.heading_color.label",
      "default": "c-heading-text-dark",
      "options": [
        {
          "value": "c-heading-text-dark",
          "label": "t:shared.settings.heading_color.option_dark"
        },
        {
          "value": "c-heading-text-light",
          "label": "t:shared.settings.heading_color.option_light"
        }
      ]
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:shared.settings.banners.text.label",
      "default": "<p>Highlight sale campaigns, discounts, and promotions.</p>"
    },
    {
      "type": "select",
      "id": "custom_text_color",
      "label": "t:shared.settings.text_color.label",
      "default": "c-body-text-dark",
      "options": [
        {
          "value": "c-body-text-dark",
          "label": "t:shared.settings.text_color.option_dark"
        },
        {
          "value": "c-body-text-light",
          "label": "t:shared.settings.text_color.option_light"
        }
      ]
    },
    {
      "type": "select",
      "id": "column_alignment_mobile",
      "label": "Mobile text alignment",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "t:shared.section_blocks.text_content.settings.alignment.option_left"
        },
        {
          "value": "center",
          "label": "t:shared.section_blocks.text_content.settings.alignment.option_center"
        },
        {
          "value": "right",
          "label": "t:shared.section_blocks.text_content.settings.alignment.option_right"
        }
      ]
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "id": "link",
      "type": "url",
      "label": "t:shared.settings.button_link.label",
      "default": "/collections"
    },
    {
      "id": "link_text",
      "type": "text",
      "label": "t:shared.settings.button_link_text.label",
      "default": "Button"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "t:shared.settings.button_style.label",
      "default": "btn--light",
      "options": [
        {
          "value": "btn--dark",
          "label": "t:shared.settings.button_style.option_solid"
        },
        {
          "value": "btn--light",
          "label": "t:shared.settings.button_style.option_outline"
        },
        {
          "value": "btn--callout",
          "label": "t:shared.settings.button_style.option_text"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:shared.settings.banners.header_background_image.content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:shared.settings.banners.image.label"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "t:shared.settings.banners.mobile_image.label"
    },
    {
      "id": "focal_point",
      "type": "select",
      "label": "t:shared.settings.focal_point.label",
      "options": [{"label":"t:shared.settings.focal_point.option_image","value":"image_presentation"},{"label":"t:shared.settings.focal_point.option_center","value":"center"},{"label":"t:shared.settings.focal_point.option_top","value":"top"},{"label":"t:shared.settings.focal_point.option_bottom","value":"bottom"},{"label":"t:shared.settings.focal_point.option_left","value":"left"},{"label":"t:shared.settings.focal_point.option_right","value":"right"}],
      "default": "image_presentation"
    },
    {
      "id": "mobile_focal_point",
      "type": "select",
      "label": "t:shared.settings.banners.mobile_focal_point.label",
      "options": [{"label":"t:shared.settings.focal_point.option_image","value":"image_presentation"},{"label":"t:shared.settings.focal_point.option_center","value":"center"},{"label":"t:shared.settings.focal_point.option_top","value":"top"},{"label":"t:shared.settings.focal_point.option_bottom","value":"bottom"},{"label":"t:shared.settings.focal_point.option_left","value":"left"},{"label":"t:shared.settings.focal_point.option_right","value":"right"}],
      "default": "image_presentation"
    },
    {
      "type": "header",
      "content": "t:shared.settings.header_color.content"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:shared.settings.text_color.label",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "t:shared.settings.buttons_background_color.label",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "t:shared.settings.button_text_color.label",
      "default": "#000000"
    },
    {
      "id": "background_color",
      "type": "color",
      "label": "t:shared.settings.banners.background_color.label",
      "info": "t:shared.settings.banners.background_color.info",
      "default": "#C51C26"
    },
    {
      "id": "color_overlay",
      "type": "color",
      "label": "t:shared.settings.color_overlay.label",
      "default": "#000"
    },
    {
      "id": "color_overlay_gradient",
      "type": "color_background",
      "label": "t:shared.settings.color_overlay_gradient.label"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:shared.settings.overlay_opacity.label",
      "unit": "%",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 0
    },
    {
      "type": "header",
      "content": "t:shared.settings.section_style.header_style.content"
    },
    {
      "id": "enable_animation",
      "type": "checkbox",
      "label": "t:shared.settings.section_style.enable_animation.label",
      "info": "t:shared.settings.section_style.enable_animation.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_frame",
      "label": "t:shared.settings.banners.show_frame.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "t:shared.settings.section_style.full_width.label",
      "default": false
    },
    {
      "type": "select",
      "id": "section_padding",
      "label": "t:shared.settings.section_style.section_padding.label",
      "default": "section--vertical-padding-top-bottom",
      "options": [
        {
          "label": "t:shared.settings.section_style.section_padding.option_none", "value": "section--vertical-padding-none"
        },
        {
          "label": "t:shared.settings.section_style.section_padding.option_both", "value": "section--vertical-padding-top-bottom"
        },
        {
          "label": "t:shared.settings.section_style.section_padding.option_top", "value": "section--vertical-padding-top-only"
        },
        {
          "label": "t:shared.settings.section_style.section_padding.option_bottom", "value": "section--vertical-padding-bottom-only"
        }
      ]
    },
    {
      "type": "range",
      "id": "corner_radius_desktop",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "t:shared.settings.section_style.corner_radius_desktop.label",
      "default": 0
    },
    {
      "type": "range",
      "id": "corner_radius_mobile",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "t:shared.settings.section_style.corner_radius_mobile.label",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Banner Callout"
    }
  ]
}
{% endschema %}