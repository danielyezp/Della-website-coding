{%- liquid
  assign prioritize_loading = false
  assign has_image = false
  assign has_media_content = false

  if section.index == 1
    assign prioritize_loading = true
  endif

  assign has_video = false

  if section.settings.image != blank
    assign has_image = true
  endif

  if section.settings.video != blank or section.settings.video_mobile != blank
    assign has_video = true
  endif

  if has_video or has_image
    assign has_media_content = true
  endif
-%}

{%- capture text_container_content -%}
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'accent' -%}
        {%- unless block.settings.accent == blank -%}
          <p class="image-with-text-split__text-container-accent fs-accent section-blocks__accent">
            {{ block.settings.accent }}
          </p>
        {%- endunless -%}
      {%- when 'heading' -%}
        {%- unless block.settings.title == blank -%}
          <{{ block.settings.heading_tag }} class="image-with-text-split__text-container-heading ff-heading {{ block.settings.heading_font_class }} {{ block.settings.font_family_class }} {% if section.settings.text_color == 'rgba(0,0,0,0)' or section.settings.text_color == blank %}{{ block.settings.heading_color }}{% endif %} section-blocks__heading">
            {{ block.settings.title }}
          </{{ block.settings.heading_tag }}>
        {%- endunless -%}
      {%- when 'subheading' -%}
        {%- unless block.settings.subheading == blank -%}
          <{{ block.settings.subheading_tag }} class="image-with-text-split__text-container-subheading ff-subheading {{ block.settings.subheading_font_class }} {{ block.settings.font_family_class }} {% if section.settings.text_color == 'rgba(0,0,0,0)' or section.settings.text_color == blank %}{{ block.settings.subheading_color }}{% endif %} section-blocks__subheading">
            {{ block.settings.subheading }}
          </{{ block.settings.subheading_tag }}>
        {%- endunless -%}
      {%- when 'text' -%}
        {%- unless block.settings.text == blank -%}
          <div class="image-with-text-split__text-container-text rte ff-body {{ block.settings.text_font_class }} {% if section.settings.text_color == 'rgba(0,0,0,0)' or section.settings.text_color == blank %}{{ block.settings.custom_text_color }}{% endif %} section-blocks__text">
            {{ block.settings.text }}
          </div>
        {%- endunless -%}
      {%- when 'image' -%}
        {%-
          render 'image-block' with
          shopify_attributes: block.shopify_attributes,
          wrapper_class: 'image-with-text-split__text-container-image  section-blocks__image',
          image: block.settings.image,
          width: block.settings.image_size,
          mobile_width: block.settings.image_size_mobile,
          break_to_mobile_at: '720',
          align: section.settings.content_alignment
        -%}
      {%- when 'button' -%}
        {%-
          render 'button-block' with
          wrapper_class: "image-with-text-split__text-container-button section-blocks__button",
          link: block.settings.link,
          label: block.settings.link_text,
          button_style: block.settings.button_style,
          button_color: block.settings.button_color
          is_overlay: true,
          button_alignment: section.settings.content_alignment,
          buttons_can_inline: true,
          forloop: forloop
        -%}
      {%- when 'play-button' -%}
        {%-
          render 'play-button-block' with
          wrapper_class: 'image-with-text-split__text-container-play-button section-blocks__video-button',
          block: block,
          button_alignment: section.settings.content_alignment
        -%}
      {%- when 'border' -%}
        {%- render 'border-block' -%}
      {%- when 'spacer' -%}
        {%- render 'spacer-block' with space: block.settings.space -%}
      {%- when 'icon_with_text' -%}
        {%- if block.settings.icon != blank or block.settings.title != blank or request.design_mode -%}
          <div class="image-with-text-split__icon-text-container">
            {%-
              render 'image' with
              wrapper_class: "image-with-text-split__icon-image",
              image: block.settings.icon,
              sizes: '50px',
              include_placeholder: true
            -%}
            {% unless block.settings.title == blank %}
              <p class="image-with-text-split__icon-text fs-body-50">{{ block.settings.title }}</p>
            {% endunless %}
          </div>
        {%- endif -%}
    {%- endcase -%}
  {%- endfor -%}
{%- endcapture -%}

{%- assign text_container_content = text_container_content | strip -%}
{%- assign has_section_content = false -%}

{%- if has_media_content or text_container_content != blank -%}
  {%- assign has_section_content = true -%}
{%- endif -%}

{% if has_section_content or request.design_mode %}
  <div
    {% if section.settings.anchor_id != blank %}id="{{ section.settings.anchor_id | strip | handleize }}"{% endif %}
    class="
      image-with-text-split
      image-with-text-split--image-position-{{ section.settings.media_position }}
      image-with-text-split--image-mobile-position-{{ section.settings.media_mobile_position }}
      image-with-text-split--image-padding-{{ section.settings.image_padding }}
      image-with-text-split--content-align-{{ section.settings.content_alignment }}
      section
      section--full-width
      {{ section.settings.section_padding }}
      {% if settings.enable_section_animations and section.settings.enable_animation %}
        animation
        animation--image-with-text-split
      {% endif %}
      {% if has_video %}
        image-with-text-split--has-video
      {% endif %}
      link-color-scheme--{{ section.settings.link_color_scheme }}
    "
    data-section-id="{{ section.id }}"
    data-section-type="image-with-text-split"
    style="
      --text-align: {{ section.settings.content_alignment }};
      --color-background: {{ section.settings.background_color }};
      --color-text: {{ section.settings.text_color }};
      --color-text-link: {{ section.settings.text_color }};
      {% render 'overlay-button-vars' with color_button_text: section.settings.button_text_color, color_button_background: section.settings.button_background_color %}
    "
  >
    <div class="image-with-text-split__inner">
      {% if has_media_content or request.design_mode %}
        <div class="image-with-text-split__image-container">
          <div class="image-with-text-split__image-container-inner {% if section.settings.video_mobile != blank %}image-with-text-split__image-container-inner--has-mobile-video{% endif %}">
            {%- if has_video -%}
              <div class="image-with-text-split__video-wrapper image-with-text-split__video-wrapper--desktop" data-video-wrapper>
                {{
                  section.settings.video
                  | video_tag: autoplay: true, muted: true, loop: true, controls: false, image_size: '720x', preload: 'metadata'
                  | replace: '<video', '<video class="image-with-text__video video"'
                }}
                {%- render 'video-pause' -%}
              </div>
              {%- if section.settings.video_mobile != blank -%}
                <div class="image-with-text-split__video-wrapper image-with-text-split__video-wrapper--mobile" data-video-wrapper>
                  {{
                    section.settings.video_mobile
                    | video_tag: autoplay: true, muted: true, loop: true, controls: false, image_size: '720x', preload: 'metadata'
                    | replace: '<video', '<video class="image-with-text__video image-with-text__video--mobile video"'
                  }}
                  {%- render 'video-pause' -%}
                </div>
              {%- endif -%}
            {%- elsif has_image or request.design_mode -%}
              {%-
                render 'image' with
                wrapper_class: "image-with-text-split__image",
                image: section.settings.image,
                sizes: "(min-width: 960px) 50vw, 100vw",
                aspect_ratio: section.settings.aspect_ratio,
                focal_point: section.settings.focal_point,
                include_placeholder: request.design_mode,
                animate: true,
                prioritize_loading: prioritize_loading,
                fallback_alt: section.settings.image.alt
              -%}
            {%- endif -%}
          </div>
        </div>
      {% endif %}
      {% if text_container_content != blank %}
        <div class="image-with-text-split__text-container">
          <div class="image-with-text-split__text-container-inner section-blocks animation--section-blocks">
            {{ text_container_content }}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
{% endif %}

