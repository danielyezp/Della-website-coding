{%- liquid
  assign max_products = section.settings.maximum_products
  assign featured_collection_section_has_nav = false
-%}

{%- for block in section.blocks -%}
  {%- liquid
    assign collection_has_more_products = false
    assign show_carousel_nav_buttons = false

    if block.type == 'product_list'
      assign featured_collection_products = block.settings.product_list
      assign raw_count = block.settings.product_list.count
    else
      assign featured_collection_products = block.settings.collection.products
      assign raw_count = block.settings.collection.products.size
      if raw_count > max_products
        assign collection_has_more_products = true
      endif
    endif

    assign slide_count = max_products
    if raw_count > 0
      assign slide_count = raw_count | at_most: max_products
    endif
    if block.settings.show_view_all and collection_has_more_products and block.settings.collection_name != blank
      assign slide_count = slide_count | plus: 1
    endif
    if slide_count > section.settings.columns
      assign show_carousel_nav_buttons = true
      assign featured_collection_section_has_nav = true
    endif

    assign carousel_navigation_class = 'featured-collection-slider__navigation-buttons animation--controls'
    if forloop.first and show_carousel_nav_buttons
      assign carousel_navigation_class = carousel_navigation_class | append: ' visible'
    endif
  -%}

  {%- capture navigation_list_items -%}
    {{ navigation_list_items }}
    <li>
      <button
        type="button"
        class="featured-collection-slider__navigation-list-item{% if forloop.first %} selected{% endif %}"
        data-navigation-item="{{ forloop.index0 }}"
      >
        <span class="ff-subheading fs-body-400">{{ block.settings.collection_name }}</span>
        <span class="indicator"></span>
      </button>
    </li>
  {%- endcapture -%}
  {%- capture navigation_buttons -%}
    {{ navigation_buttons }}
    {%- if show_carousel_nav_buttons -%}
      {%- capture index_attribute -%}data-navigation="{{ forloop.index0 }}"{%- endcapture -%}
      {%- render 'carousel-navigation' with wrapper_class: carousel_navigation_class, data_attribute: index_attribute -%}
    {%- endif -%}
  {%- endcapture -%}

  {%- capture carousel_elements -%}
    {{ carousel_elements }}
    <div
      class="featured-collection-slider__content carousel swiper{% if forloop.first %} visible{% endif %}"
      data-collection="{{ forloop.index0 }}"
      {{ block.shopify_attributes }}
    >
      <div class="featured-collection-slider__products carousel__wrapper swiper-wrapper">
        {%- for product in featured_collection_products limit: max_products -%}
          <div class="featured-collection-slider__product carousel__slide swiper-slide">
            {% render 'product-item', prod: product, collection: block.settings.collection, aspect_ratio: settings.product_listing_aspect_ratio, product_columns: section.settings.columns, hide_price: section.settings.hide_price %}
          </div>
        {%- else -%}
          {%- for i in (1..max_products) -%}
            <div class="featured-collection-slider__product carousel__slide swiper-slide">
              {% render 'product-item', aspect_ratio: settings.product_listing_aspect_ratio, product_columns: section.settings.columns, placeholder: true, hide_price: section.settings.hide_price %}
            </div>
          {%- endfor -%}
        {%- endfor -%}

        {%- if block.settings.show_view_all and collection_has_more_products and block.settings.collection_name != blank -%}
          <div class="featured-collection-slider__content-view-all-wrapper swiper-slide">
            <div class="featured-collection-slider__content-view-all">
              <h4 class="featured-collection-slider__content-view-all-header ff-heading fs-heading-4-base">
                {{ block.settings.collection_name }}
              </h4>
              <a
                href="{{ block.settings.collection.url }}"
                class="featured-collection-slider__view-all btn btn--callout"
              >
                <span>
                  {{- 'collections.general.view_all' | t -}}
                </span>
              </a>
            </div>
          </div>
        {%- endif -%}
      </div>
      {%- render 'carousel-scrollbar', class: 'js-scrollbar featured-collection-slider__scrollbar animation--controls' -%}
    </div>
  {%- endcapture -%}
{%- endfor -%}

<div
  {% if section.settings.anchor_id != blank %}id="{{ section.settings.anchor_id | strip | handleize }}"{% endif %}
  class="
    featured-collection-slider
    featured-collection-slider--mobile-per-view-{{ section.settings.mobile_columns }}
    featured-collection-slider--per-view-{{ section.settings.mobile_columns }}
    section
    section--large-gaps
    section--includes-product-items
    section--divider-{{ section.settings.divider_style }}
    {{ section.settings.section_padding }}
    {% if settings.enable_section_animations and section.settings.enable_animation %}
      animation
      animation--list-slider
    {% endif %}
    link-color-scheme--{{ section.settings.link_color_scheme }}
  "
  data-section-id="{{ section.id }}"
  data-section-type="featured-collection-slider"
  data-products-per-view="{{ section.settings.columns }}"
  data-mobile-products-per-view="{{ section.settings.mobile_columns }}"
>
  <div class="featured-collection-slider__inner">
    <div class="featured-collection-slider__meta{% if section.blocks.size == 1 %} carousel__navigation-wrapper{% endif %}">
      <div class="section-introduction animation--section-introduction">
        {%- unless section.settings.heading == blank -%}
          <{{ section.settings.heading_tag }} class="featured-collection-slider__heading section-introduction__heading ff-heading {{ section.settings.heading_font_class }}">
            {{ section.settings.heading }}
          </{{ section.settings.heading_tag }}>
        {%- endunless -%}

        {%- unless section.settings.subheading == blank -%}
          <div class="featured-collection-slider__subheading section-introduction__subheading rte ff-body fs-body-100">
            {{ section.settings.subheading }}
          </div>
        {%- endunless -%}

        {%-
          render 'button-block' with
          wrapper_class: "featured-collection-slider__header-button section-introduction__button",
          link: section.settings.link,
          label: section.settings.link_text,
          button_style: section.settings.button_style
        -%}

        {%- if section.blocks.size > 1 -%}
          <ul class="featured-collection-slider__navigation-list animation--controls">
            {{ navigation_list_items }}
          </ul>
        {%- endif -%}
      </div>
      {%- if section.blocks.size > 0 and featured_collection_section_has_nav -%}
        {{ navigation_buttons }}
      {%- endif -%}
    </div>

    {{ carousel_elements }}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.featured_collection_slider.name",
  "tag": "section",
  "class": "featured-collections-slider-wrap",
  "disabled_on": {
    "groups": ["header", "custom.overlay"],
    "templates": ["password"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:shared.settings.anchor.content"
    },
    {
      "type": "text",
      "id": "anchor_id",
      "label": "t:shared.settings.anchor.anchor_id.label",
      "info": "t:shared.settings.anchor.anchor_id.info"
    },
    {
      "type": "header",
      "content": "t:sections.collection_sections_shared.settings.header_heading.content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.collection_sections_shared.settings.title.label",
      "default": "Featured collection"
    },
    {
      "type": "select",
      "id": "heading_font_class",
      "label": "t:shared.settings.heading_font_class.label",
      "default": "fs-heading-3-base",
      "options": [
        {
          "value": "fs-heading-1-base",
          "label": "t:shared.settings.heading_font_class.option_heading_1"
        },
        {
          "value": "fs-heading-2-base",
          "label": "t:shared.settings.heading_font_class.option_heading_2"
        },
        {
          "value": "fs-heading-3-base",
          "label": "t:shared.settings.heading_font_class.option_heading_3"
        },
        {
          "value": "fs-heading-4-base",
          "label": "t:shared.settings.heading_font_class.option_heading_4"
        },
        {
          "value": "fs-heading-5-base",
          "label": "t:shared.settings.heading_font_class.option_heading_5"
        },
        {
          "value": "fs-heading-6-base",
          "label": "t:shared.settings.heading_font_class.option_heading_6"
        }
      ]
    },
    {
      "id": "heading_tag",
      "type": "select",
      "label": "t:shared.section_blocks.heading.settings.heading_tag.label",
      "default": "h2",
      "options": [
        {
          "value": "h2",
          "label": "t:shared.section_blocks.heading.settings.heading_tag.options.h2"
        },
        {
          "value": "h3",
          "label": "t:shared.section_blocks.heading.settings.heading_tag.options.h3"
        },
        {
          "value": "h4",
          "label": "t:shared.section_blocks.heading.settings.heading_tag.options.h4"
        },
        {
          "value": "h5",
          "label": "t:shared.section_blocks.heading.settings.heading_tag.options.h5"
        },
        {
          "value": "h6",
          "label": "t:shared.section_blocks.heading.settings.heading_tag.options.h6"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": "t:shared.section_blocks.heading.settings.heading_tag.info"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "t:sections.collection_sections_shared.settings.subheading.label"
    },
    {
      "id": "link",
      "type": "url",
      "label": "t:sections.shoppable_feature.settings.link.label"
    },
    {
      "id": "link_text",
      "type": "text",
      "label": "t:sections.shoppable_feature.settings.link_text.label"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "t:shared.settings.button_style.label",
      "default": "btn--callout",
      "options": [
        {
          "value": "btn--dark",
          "label": "t:shared.settings.button_style.option_solid"
        },
        {
          "value": "btn--light",
          "label": "t:shared.settings.button_style.option_outline"
        },
        {
          "value": "btn--callout",
          "label": "t:shared.settings.button_style.option_text"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.collection_sections_shared.settings.header_product_list.content"
    },
    {
      "type": "checkbox",
      "id": "hide_price",
      "label": "t:sections.collection_sections_shared.settings.hide_price.label",
      "default": false
    },
    {
      "type": "range",
      "id": "maximum_products",
      "label": "t:sections.collection_sections_shared.settings.maximum_products.label",
      "min": 3,
      "max": 15,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "t:shared.settings.column_count.desktop.label"
    },
    {
      "type": "range",
      "id": "mobile_columns",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.2,
      "label": "t:shared.settings.column_count.mobile.label"
    },
    {
      "type": "header",
      "content": "t:shared.settings.section_style.header_style.content"
    },
    {
      "id": "enable_animation",
      "type": "checkbox",
      "label": "t:shared.settings.section_style.enable_animation.label",
      "info": "t:shared.settings.section_style.enable_animation.info",
      "default": true
    },
    {
      "type": "select",
      "id": "divider_style",
      "label": "t:shared.settings.section_style.divider_style.label",
      "default": "none",
      "options": [
        {
          "label": "t:shared.settings.section_style.divider_style.option_none",
          "value": "none"
        },
        {
          "label": "t:shared.settings.section_style.divider_style.option_solid",
          "value": "solid"
        }
      ]
    },
    {
      "type": "select",
      "id": "section_padding",
      "label": "t:shared.settings.section_style.section_padding.label",
      "default": "section--vertical-padding-top-bottom",
      "options": [
        {
          "label": "t:shared.settings.section_style.section_padding.option_none",
          "value": "section--vertical-padding-none"
        },
        {
          "label": "t:shared.settings.section_style.section_padding.option_both",
          "value": "section--vertical-padding-top-bottom"
        },
        {
          "label": "t:shared.settings.section_style.section_padding.option_top",
          "value": "section--vertical-padding-top-only"
        },
        {
          "label": "t:shared.settings.section_style.section_padding.option_bottom",
          "value": "section--vertical-padding-bottom-only"
        }
      ]
    },
    {
      "type": "select",
      "id": "link_color_scheme",
      "label": "t:shared.settings.link_color_scheme.label",
      "options": [
        {
          "value": "light",
          "label": "t:shared.settings.link_color_scheme.option_light"
        },
        {
          "value": "dark",
          "label": "t:shared.settings.link_color_scheme.option_dark"
        }
      ],
      "default": "dark"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "t:sections.featured_collection_slider.blocks.collection.name",
      "limit": 5,
      "settings": [
        {
          "type": "header",
          "content": "t:sections.collection_sections_shared.settings.header__view_all.content"
        },
        {
          "id": "show_view_all",
          "type": "checkbox",
          "label": "t:sections.collection_sections_shared.settings.show_view_all.label",
          "info": "t:sections.collection_sections_shared.settings.show_view_all.info",
          "default": true
        },
        {
          "id": "collection",
          "type": "collection",
          "label": "t:sections.collection_sections_shared.settings.collection.label"
        },
        {
          "type": "text",
          "id": "collection_name",
          "label": "t:sections.featured_collection_slider.blocks.collection.settings.collection_name.label",
          "default": "Collection"
        }
      ]
    },
    {
      "type": "product_list",
      "name": "t:sections.featured_collection_slider.blocks.product_list.name",
      "limit": 3,
      "settings": [
        {
          "id": "product_list",
          "type": "product_list",
          "label": "t:sections.collection_sections_shared.settings.product_list.label"
        },
        {
          "type": "text",
          "id": "collection_name",
          "label": "t:sections.featured_collection_slider.blocks.collection.settings.collection_name.label",
          "default": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured_collection_slider.presets.name",
      "blocks": [
        {
          "type": "collection",
          "settings": {
            "collection_name": "First collection"
          }
        },
        {
          "type": "collection",
          "settings": {
            "collection_name": "Second collection"
          }
        }
      ]
    }
  ]
}
{% endschema %}
