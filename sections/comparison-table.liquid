{%- liquid
  assign columns = section.settings.column_1_name | append: '|' | append: section.settings.column_2_name | append: '|' | append: section.settings.column_3_name | append: '|' | append: section.settings.column_4_name | append: '|' | append: section.settings.column_5_name

  if section.settings.compare_products != blank
    assign products = section.settings.compare_products
    assign default_layout = false
  else
    assign products = columns | split: '|'
    assign default_layout = true
  endif

  if section.settings.compare_titles != blank
    assign rows = section.settings.compare_titles | split: ', '
  endif

  assign column_class = 'comparison-table__cell'
  assign cell_top_class = 'comparison-table__cell comparison-table__cell--top js-pc-cell-top'
  assign highlight_color = section.settings.highlight_color
  assign tick_icon = section.settings.tick_icon | image_url
  assign x_icon = section.settings.x_icon | image_url
  assign button_1_label = section.settings.button_1_label
  assign button_1_color = section.settings.button_1_color
  assign button_1_style = section.settings.button_1_style
  assign button_1_link = section.settings.button_1_link
  assign button_2_label = section.settings.button_2_label
  assign button_2_color = section.settings.button_2_color
  assign button_2_style = section.settings.button_2_style
  assign button_2_link = section.settings.button_2_link
  assign shop_now_label = 'products.product.comparison.shop_now' | t

  assign show_animations = false
  if settings.enable_section_animations and section.settings.enable_animation
    assign show_animations = true
  endif
-%}

{%- if products and rows -%}
  <div
    {% if section.settings.anchor_id != blank %}id="{{ section.settings.anchor_id | strip | handleize }}"{% endif %}
    class="
      comparison-table
      {% if show_animations %}
        animation
        animation--comparison-table
      {% endif %}
      {% if section.settings.background_image %}
        comparison-table--has-background-image
      {% endif %}
    "
    data-section-id="{{ section.id }}"
    data-section-type="comparison-table"
  >
    {%- if section.settings.background_image -%}
      <div class="comparison-table__background-image" aria-hidden="true">
        {%-
          render 'image',
          wrapper_class: "comparison-table__background",
          image: section.settings.background_image
        -%}
      </div>
    {%- endif -%}
    <div class="comparison-table__container section section--large-gaps {{ section.settings.section_padding }} {% if show_animations %}animation--section-blocks{% endif %}">
      {%- if section.settings.headline != blank -%}
        <div class="comparison-table__headline fs-body-50">{{ section.settings.headline }}</div>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="comparison-table__heading fs-heading-2-base ff-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      <div class="comparison-table__inner js-comparison-table comparison-table__center">
        <div class="comparison-table__header js-comparison-header {% if products.size > 6 %}comparison-table__header--overflow{% endif %}">
          <ul class="comparison-table__column js-comparison-column">
            <li class="{{ cell_top_class }} fs-body-50">
              <span class="hidden">{{ 'products.product.comparison.models' | t }}</span>
            </li>
            {%- for row in rows -%}
              <li data-row="{{ forloop.index }}" class="{{ column_class }} comparison-table__cell--{{ row | handleize }} ff-subheading fs-body-200">{{ row }}</li>
            {%- endfor -%}
            <li class="compare-row {{ column_class }} compare-row--shop-now {% unless section.settings.show_shop_button %}compare-row--hide-button{% endunless %}">
              <p class="fs-body-50 hidden">{{ 'products.product.comparison.shop_now' | t }}</p>
            </li>
          </ul>
        </div>
        <div class="comparison-table__products js-comparison-scroll" style="--halo-scrollbar-background: {{ settings.color_border | color_modify: 'alpha', 0.6 }};">
          <ul class="comparison-table__columns js-comparison-content">
            <li class="comparison-table__item--current comparison-table__item {% if default_layout %}comparison-table__item--default{% endif %}">
              {%- if section.settings.highlight_product != blank -%}
                {%- assign product = section.settings.highlight_product -%}
              {%- endif -%}
              {%- liquid
                assign product_image = product.featured_image
                if product_image contains 'no-image' or default_layout
                  assign product_image = null
                endif
                if default_layout == false
                  assign product_image = null
                endif
                if section.settings.featured_column_image != blank and default_layout
                  assign product_image = section.settings.featured_column_image
                endif
                assign shop_now_url = section.settings.featured_column_url
                if product.url != blank
                  assign shop_now_url = product.url
                endif

              -%}
              <ul
                class="comparison-table__column comparison-table__column--current js-comparison-column"
                style="--background-color: {{ highlight_color }};"
              >
                <li class="{{ cell_top_class }}">
                  {% if product_image %}
                    <div class="comparison-table__image">
                      {%-
                        render 'image',
                        image: product_image,
                        include_placeholder: true,
                        src_set_type: "grid",
                        object_fit: 'contain',
                        class_name: 'object-contain'
                      -%}
                    </div>
                  {% endif %}
                  <h3 class="comparison-table__product-title fs-heading-6-base ff-heading">
                    {% if default_layout %}
                      {{ section.settings.featured_column }}
                    {% else %}
                      {{ product.title }}
                    {% endif %}
                  </h3>
                </li>
                {%- for row in rows -%}
                  <li data-row="{{ forloop.index }}" class="compare-row {{ column_class }} comparison-table__cell--{{ row | handleize }}">
                    {% if default_layout %}
                      {%- assign featured_title = section.settings.featured_column | strip | downcase -%}
                      {%- assign row_name = row | strip | downcase -%}
                        {%- for block in section.blocks -%}
                          {%- assign parent = block.settings.parent | strip | downcase -%}
                          {%- assign name = block.settings.name | strip | downcase -%}
                          {%- if name == row_name and parent == featured_title -%}
                            <div class="comparison-table__value fs-body-50">
                              {%- if block.settings.value_image != blank -%}
                                {%-
                                  render 'image',
                                  image: block.settings.value_image,
                                  wrapper_class: 'comparison-icon',
                                  aspect-ratio: 'square'
                                -%}
                              {%- elsif block.settings.value_rating > 0 -%}
                                {%- assign block_rating_value = block.settings.value_rating | default: 0 | plus: 0 -%}
                                <div class="comparison-table__rating" aria-label="{{ block_rating_value }} of 5">
                                  {%- for i in (1..5) -%}
                                    <span class="comparison-table__rating-dot{% if i <= block_rating_value %} comparison-table__rating-dot--filled{% endif %}" aria-hidden="true"></span>
                                  {%- endfor -%}
                                </div>
                              {%- else -%}
                                {{ block.settings.value_text }}
                              {%- endif -%}
                            </div>
                          {%- endif -%}
                        {%- endfor -%}
                    {% else %}
                      {%- assign current_product_comparison_values = product.metafields.bbf.comparison_value.value -%}
                      {%- if current_product_comparison_values != blank -%}
                        {%- for comparison_value in current_product_comparison_values -%}
                          {%- assign row_handleize = row | handleize -%}
                          {%- assign comparison_value_title_handleize = comparison_value.title | handleize -%}
                          {%- if comparison_value_title_handleize == row_handleize -%}
                            <div class="comparison-table__value fs-body-50">
                              {%- case comparison_value.data_type -%}
                                {%- when 'Text' -%}
                                  {{ comparison_value.text }}
                                {%- when 'True/False' -%}
                                  {%- if comparison_value.true_false -%}
                                    {%-
                                      render 'image',
                                      image: tick_icon,
                                      wrapper_class: 'comparison-icon',
                                      aspect-ratio: 'square'
                                    -%}
                                  {%- else -%}
                                    {%-
                                      render 'image',
                                      image: x_icon,
                                      wrapper_class: 'comparison-icon',
                                      aspect-ratio: 'square'
                                    -%}
                                  {%- endif -%}
                                {%- when 'Rating' -%}
                                  {%- assign rating_raw = comparison_value.rating.value | default: comparison_value.rating | strip -%}
                                  {%- assign rating_value = rating_raw | default: 0 | plus: 0 -%}
                                  {%- if rating_value > 0 -%}
                                    <div class="comparison-table__rating" aria-label="{{ rating_value }} of 5">
                                      {%- for i in (1..5) -%}
                                        <span class="comparison-table__rating-dot{% if i <= rating_value %} comparison-table__rating-dot--filled{% endif %}" aria-hidden="true"></span>
                                      {%- endfor -%}
                                    </div>
                                  {%- endif -%}
                                {%- else -%}
                                  {{ product.price | money }}
                              {%- endcase -%}
                            </div>
                          {%- endif -%}
                        {%- endfor -%}
                      {%- endif -%}
                    {% endif %}
                  </li>
                {%- endfor -%}
                <li class="compare-row {{ column_class }} compare-row--shop-now {% unless section.settings.show_shop_button %}compare-row--hide-button{% endunless %}{% if default_layout == false %} compare-row--shop-now-metafield{% endif %}">
                  {%- if default_layout and section.settings.show_shop_button and shop_now_url != blank -%}
                    {%-
                      render 'button-block' with
                      wrapper_class: 'fs-body-50 ff-body fs-body-normal comparison-table__product-link',
                      link: shop_now_url,
                      label: shop_now_label,
                      is_overlay: true,
                      buttons_can_inline: true,
                      is_small: true,
                      button_style: 'btn--callout',
                      button_color: 'btn--dark'
                    -%}
                  {%- endif -%}
                </li>
              </ul>
            </li>
            {%- for pro in products -%}
              {%- assign column_title = pro | strip | downcase -%}
              <li class="comparison-table__item {% if default_layout %}comparison-table__item--default{% endif %}">
                {%- liquid
                  assign product_image = pro.featured_image

                  if product_image contains 'no-image' or default_layout
                    assign product_image = null
                  endif
                  if default_layout == false
                    assign product_image = null
                  endif

                  assign index = forloop.index
                  assign product_image_key = 'column_[cc]_image' | replace: '[cc]', index
                  assign product_url_key = 'column_[cc]_url' | replace: '[cc]', index

                  if section.settings[product_image_key] != blank and default_layout
                    assign product_image = section.settings[product_image_key]
                  endif

                  assign shop_now_url = section.settings[product_url_key]
                  if pro.url != blank
                    assign shop_now_url = pro.url
                  endif
                -%}
                <ul class="comparison-table__column js-comparison-column">
                  <li class="{{ cell_top_class }}">
                    {% if product_image != null %}
                      <div class="comparison-table__image">
                        {%-
                          render 'image',
                          image: product_image,
                          include_placeholder: true,
                          src_set_type: "grid",
                          object_fit: 'contain',
                          class_name: 'object-contain'
                        -%}
                      </div>
                    {% endif %}
                    <h3 class="comparison-table__product-title fs-heading-6-base ff-heading">
                      {% if default_layout %}
                        {{ pro }}
                      {% else %}
                        {{ pro.title }}
                      {% endif %}
                    </h3>
                  </li>
                  {%- for row in rows -%}
                    <li data-row="{{ forloop.index }}" class="compare-row {{ column_class }} comparison-table__cell--{{ row | handleize }}">
                      {%- if default_layout -%}
                        {%- assign row_name = row | strip | downcase -%}
                        {%- for block in section.blocks -%}
                          {%- assign parent = block.settings.parent | strip | downcase -%}
                          {%- assign name = block.settings.name | strip | downcase -%}
                          {%- if name == row_name and parent == column_title -%}
                            <div class="comparison-table__value fs-body-50">
                              {%- if block.settings.value_image != blank -%}
                                {%-
                                  render 'image',
                                  image: block.settings.value_image
                                  wrapper_class: 'comparison-icon',
                                  aspect-ratio: 'square'
                                -%}
                              {%- elsif block.settings.value_rating > 0 -%}
                                {%- assign block_rating_value = block.settings.value_rating | default: 0 | plus: 0 -%}
                                <div class="comparison-table__rating" aria-label="{{ block_rating_value }} of 5">
                                  {%- for i in (1..5) -%}
                                    <span class="comparison-table__rating-dot{% if i <= block_rating_value %} comparison-table__rating-dot--filled{% endif %}" aria-hidden="true"></span>
                                  {%- endfor -%}
                                </div>
                              {%- else -%}
                                {{ block.settings.value_text }}
                              {%- endif -%}
                            </div>
                          {%- endif -%}
                        {%- endfor -%}
                      {%- else -%}
                        {%- assign current_product_comparison_values = pro.metafields.bbf.comparison_value.value -%}
                        {%- if current_product_comparison_values != blank -%}
                          {%- for comparison_value in current_product_comparison_values -%}
                            {%- assign row_handleize = row | handleize -%}
                            {%- assign comparison_value_title_handleize = comparison_value.title | handleize -%}
                            {%- if comparison_value_title_handleize == row_handleize -%}
                              <div class="comparison-table__value fs-body-50">
                                {%- case comparison_value.data_type -%}
                                  {%- when 'Text' -%}
                                    {{ comparison_value.text }}
                                  {%- when 'True/False' -%}
                                    {%- if comparison_value.true_false -%}
                                      {%-
                                        render 'image',
                                        image: tick_icon,
                                        wrapper_class: 'comparison-icon'
                                      -%}
                                    {%- else -%}
                                      {%-
                                        render 'image',
                                        image: x_icon,
                                        wrapper_class: 'comparison-icon'
                                      -%}
                                    {%- endif -%}
                                  {%- when 'Rating' -%}
                                    {%- assign rating_raw = comparison_value.rating.value | default: comparison_value.rating | strip -%}
                                    {%- assign rating_value = rating_raw | default: 0 | plus: 0 -%}
                                    {%- if rating_value > 0 -%}
                                      <div class="comparison-table__rating" aria-label="{{ rating_value }} of 5">
                                        {%- for i in (1..5) -%}
                                          <span class="comparison-table__rating-dot{% if i <= rating_value %} comparison-table__rating-dot--filled{% endif %}" aria-hidden="true"></span>
                                        {%- endfor -%}
                                      </div>
                                    {%- endif -%}
                                  {%- else -%}
                                    {{ pro.price | money }}
                                {%- endcase -%}
                              </div>
                            {%- endif -%}
                          {%- endfor -%}
                        {%- endif -%}
                      {%- endif -%}
                    </li>
                  {%- endfor -%}
                  <li class="compare-row {{ column_class }} compare-row--shop-now {% unless section.settings.show_shop_button %}compare-row--hide-button{% endunless %}">
                    {%- if section.settings.show_shop_button and shop_now_url != blank -%}
                      {%-
                        render 'button-block' with
                        wrapper_class: 'fs-body-50 ff-body fs-body-normal comparison-table__product-link',
                        link: shop_now_url,
                        label: shop_now_label,
                        is_overlay: true,
                        buttons_can_inline: true,
                        is_small: true,
                        button_style: 'btn--callout',
                        button_color: 'btn--dark'
                      -%}
                    {%- endif -%}
                  </li>
                </ul>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </div>
      {%- if button_1_label != blank and button_2_label != blank -%}
        <div class="comparison-table__actions">
          {%- if button_1_label != blank -%}
            {%- render 'button-block',
              link: button_1_link,
              label: button_1_label,
              button_style: button_1_style,
              button_color: button_1_color
            -%}
          {%- endif -%}
          {%- if button_2_label != blank -%}
            {%- render 'button-block',
              link: button_2_link,
              label: button_2_label,
              button_style: button_2_style,
              button_color: button_2_color
            -%}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.comparison_table.name",
  "settings": [
    {
      "type": "header",
      "content": "t:shared.settings.anchor.content"
    },
    {
      "type": "text",
      "id": "anchor_id",
      "label": "t:shared.settings.anchor.anchor_id.label",
      "info": "t:shared.settings.anchor.anchor_id.info"
    },
    {
      "type": "header",
      "content": "t:sections.comparison_table.settings.background_image.content"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:sections.comparison_table.settings.background_image.label"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "t:sections.comparison_table.settings.headline.label",
      "default": "Headline"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.comparison_table.settings.heading.label",
      "default": "Comparison table"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "t:sections.comparison_table.settings.highlight_color.label",
      "default": "#EEF5FB"
    },
    {
      "type": "text",
      "id": "compare_titles",
      "label": "t:sections.comparison_table.settings.compare_titles.label",
      "default": "Title 1, Title 2, Title 3, Title 4, Title 5"
    },
    {
      "type": "header",
      "content": "t:sections.comparison_table.settings.default_content_header.content"
    },
    {
      "type": "text",
      "id": "featured_column",
      "label": "t:sections.comparison_table.settings.featured_column.label",
      "default": "Featured Column"
    },
    {
      "type": "image_picker",
      "id": "featured_column_image",
      "label": "t:sections.comparison_table.settings.featured_column_image.label"
    },
    {
      "type": "url",
      "id": "featured_column_url",
      "label": "t:sections.comparison_table.settings.featured_column_url.label"
    },
    {
      "type": "text",
      "id": "column_1_name",
      "label": "t:sections.comparison_table.settings.column_1_name.label",
      "default": "Column 1"
    },
    {
      "type": "image_picker",
      "id": "column_1_image",
      "label": "t:sections.comparison_table.settings.column_1_image.label"
    },
    {
      "type": "url",
      "id": "column_1_url",
      "label": "t:sections.comparison_table.settings.column_1_url.label"
    },
    {
      "type": "text",
      "id": "column_2_name",
      "label": "t:sections.comparison_table.settings.column_2_name.label",
      "default": "Column 2"
    },
    {
      "type": "image_picker",
      "id": "column_2_image",
      "label": "t:sections.comparison_table.settings.column_2_image.label"
    },
    {
      "type": "url",
      "id": "column_2_url",
      "label": "t:sections.comparison_table.settings.column_2_url.label"
    },
    {
      "type": "text",
      "id": "column_3_name",
      "label": "t:sections.comparison_table.settings.column_3_name.label",
      "default": "Column 3"
    },
    {
      "type": "image_picker",
      "id": "column_3_image",
      "label": "t:sections.comparison_table.settings.column_3_image.label"
    },
    {
      "type": "url",
      "id": "column_3_url",
      "label": "t:sections.comparison_table.settings.column_3_url.label"
    },
    {
      "type": "text",
      "id": "column_4_name",
      "label": "t:sections.comparison_table.settings.column_4_name.label",
      "default": "Column 4"
    },
    {
      "type": "image_picker",
      "id": "column_4_image",
      "label": "t:sections.comparison_table.settings.column_4_image.label"
    },
    {
      "type": "url",
      "id": "column_4_url",
      "label": "t:sections.comparison_table.settings.column_4_url.label"
    },
    {
      "type": "text",
      "id": "column_5_name",
      "label": "t:sections.comparison_table.settings.column_5_name.label",
      "default": "Column 5"
    },
    {
      "type": "image_picker",
      "id": "column_5_image",
      "label": "t:sections.comparison_table.settings.column_5_image.label"
    },
    {
      "type": "url",
      "id": "column_5_url",
      "label": "t:sections.comparison_table.settings.column_5_url.label"
    },
    {
      "type": "header",
      "content": "t:sections.comparison_table.settings.product_content_header.content"
    },
    {
      "type": "product",
      "id": "highlight_product",
      "label": "t:sections.comparison_table.settings.highlight_product.label"
    },
    {
      "type": "product_list",
      "id": "compare_products",
      "limit": 5,
      "label": "t:sections.comparison_table.settings.compare_products.label"
    },
    {
      "type": "checkbox",
      "id": "show_shop_button",
      "label": "t:sections.comparison_table.settings.show_shop_button.label",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "tick_icon",
      "label": "t:sections.comparison_table.settings.tick_icon.label"
    },
    {
      "type": "image_picker",
      "id": "x_icon",
      "label": "t:sections.comparison_table.settings.x_icon.label"
    },
    {
      "type": "header",
      "content": "t:sections.comparison_table.settings.button_cta_header.content"
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "t:sections.comparison_table.settings.button_1_label.label",
      "default": "Button"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "t:sections.comparison_table.settings.button_1_link.label"
    },
    {
      "type": "select",
      "id": "button_1_color",
      "label": "t:sections.comparison_table.settings.button_1_color.label",
      "options": [
        {
          "value": "btn--dark",
          "label": "t:shared.settings.button_color.dark"
        },
        {
          "value": "btn--light",
          "label": "t:shared.settings.button_color.light"
        }
      ],
      "default": "btn--dark"
    },
    {
      "type": "select",
      "id": "button_1_style",
      "label": "t:sections.comparison_table.settings.button_1_style.label",
      "options": [
        {
          "value": "btn--solid",
          "label": "t:shared.settings.button_style.option_solid"
        },
        {
          "value": "btn--outline",
          "label": "t:shared.settings.button_style.option_outline"
        },
        {
          "value": "btn--callout",
          "label": "t:shared.settings.button_style.option_text"
        }
      ],
      "default": "btn--solid"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "t:sections.comparison_table.settings.button_2_label.label",
      "default": "Button"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "t:sections.comparison_table.settings.button_2_link.label"
    },
    {
      "type": "select",
      "id": "button_2_color",
      "label": "t:sections.comparison_table.settings.button_2_color.label",
      "options": [
        {
          "value": "btn--dark",
          "label": "t:shared.settings.button_color.dark"
        },
        {
          "value": "btn--light",
          "label": "t:shared.settings.button_color.light"
        }
      ],
      "default": "btn--dark"
    },
    {
      "type": "select",
      "id": "button_2_style",
      "label": "t:sections.comparison_table.settings.button_2_style.label",
      "options": [
        {
          "value": "btn--solid",
          "label": "t:shared.settings.button_style.option_solid"
        },
        {
          "value": "btn--outline",
          "label": "t:shared.settings.button_style.option_outline"
        },
        {
          "value": "btn--callout",
          "label": "t:shared.settings.button_style.option_text"
